<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-2">
  <.e_nav active_tab="discussions" current_user={@current_user} />
  <% category_pills = [
    {"all", "All"},
    {"programming", "Programming"},
    {"tech", "Tech"},
    {"science", "Science"},
    {"gaming", "Gaming"},
    {"art", "Art"},
    {"photography", "Photo"},
    {"news", "News"}
  ]

  joined_count = length(@filtered_communities || []) + length(@filtered_remote_communities || [])
  search_active? = String.trim(@search_query || "") != ""
  search_scope = @search_scope || "communities"

  search_counts = %{
    "communities" => length((@search_results_by_scope || %{})["communities"] || []),
    "posts" => length((@search_results_by_scope || %{})["posts"] || []),
    "people" => length((@search_results_by_scope || %{})["people"] || [])
  }

  search_placeholder =
    case search_scope do
      "posts" -> "Search discussion posts and threads"
      "people" -> "Search people by handle or display name"
      _ -> "Search communities or paste !community@server"
    end

  discover_public_communities =
    (@filtered_public_communities || [])
    |> Enum.reject(&MapSet.member?(@joined_community_ids, &1.id))

  discover_remote_communities = @filtered_discover_remote_communities || []
  sidebar_federated_suggestions = Enum.take(@filtered_discover_remote_communities || [], 3)
  feed_post_count = length(@filtered_community_posts || [])

  spotlight_communities = @filtered_popular_communities || []
  trending_threads = @filtered_discussions || []
  recent_threads = @filtered_recent_activity || []
  federated_threads = @filtered_federated_discussions || []
  discover_cards = build_discovery_cards(spotlight_communities, discover_public_communities)
  visible_discover_cards = Enum.take(discover_cards, @overview_card_limit || 6)
  visible_remote_communities = Enum.take(discover_remote_communities, @overview_card_limit || 6)

  active_thread_cards =
    build_active_thread_cards(trending_threads, recent_threads, federated_threads)

  visible_active_thread_cards = Enum.take(active_thread_cards, @overview_card_limit || 6)

  joinable_trending_communities =
    (@filtered_popular_communities || [])
    |> Enum.reject(&MapSet.member?(@joined_community_ids, &1.id))
    |> Enum.take(3)

  selected_category_label =
    if @selected_category == "all",
      do: "your interests",
      else: String.capitalize(@selected_category) %>

  <div class="sm:hidden mb-4 space-y-3">
    <%= if @current_user do %>
      <button
        phx-click="toggle_create_community"
        class="btn btn-secondary w-full min-h-[2.75rem]"
        aria-label={gettext("Create new community")}
      >
        <.icon name="hero-plus" class="w-5 h-5 mr-2" />
        {gettext("New Community")}
      </button>
    <% end %>

    <div class="grid grid-cols-3 gap-2" role="tablist" aria-label="Community views">
      <button
        phx-click="set_view"
        phx-value-view="feed"
        role="tab"
        aria-selected={@current_view == "feed"}
        class={[
          "btn h-auto min-h-16 flex-col gap-1 rounded-2xl px-3 py-3 text-sm font-medium relative",
          if(@current_view == "feed",
            do: "btn-secondary",
            else: "btn-ghost bg-base-200/60 hover:bg-base-200 text-base-content/70"
          )
        ]}
      >
        <div class="flex flex-col items-center gap-1">
          <.icon name="hero-rss" class="w-5 h-5" />
          <span>Feed</span>
        </div>
        <%= if length(@followed_community_posts) > 0 do %>
          <span class="badge badge-xs badge-primary absolute top-1 right-1">
            {length(@followed_community_posts)}
          </span>
        <% end %>
      </button>
      <button
        phx-click="set_view"
        phx-value-view="communities"
        role="tab"
        aria-selected={@current_view == "communities"}
        class={[
          "btn h-auto min-h-16 flex-col gap-1 rounded-2xl px-3 py-3 text-sm font-medium relative",
          if(@current_view == "communities",
            do: "btn-secondary",
            else: "btn-ghost bg-base-200/60 hover:bg-base-200 text-base-content/70"
          )
        ]}
      >
        <div class="flex flex-col items-center gap-1">
          <.icon name="hero-user-group" class="w-5 h-5" />
          <span>Joined</span>
        </div>
      </button>
      <button
        phx-click="set_view"
        phx-value-view="my_activity"
        role="tab"
        aria-selected={@current_view == "my_activity"}
        class={[
          "btn h-auto min-h-16 flex-col gap-1 rounded-2xl px-3 py-3 text-sm font-medium relative",
          if(@current_view == "my_activity",
            do: "btn-secondary",
            else: "btn-ghost bg-base-200/60 hover:bg-base-200 text-base-content/70"
          )
        ]}
      >
        <div class="flex flex-col items-center gap-1">
          <.icon name="hero-document-text" class="w-5 h-5" />
          <span>My Activity</span>
        </div>
      </button>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-4 lg:gap-6">
    <div class="hidden sm:block w-64 xl:w-72 flex-shrink-0 sticky top-36 self-start max-h-[calc(100vh-11rem)] z-20">
      <div class="card panel-card rounded-lg">
        <div class="card-body p-4 space-y-4">
          <%= if @current_user do %>
            <button
              phx-click="toggle_create_community"
              class="btn btn-secondary btn-sm w-full"
            >
              <.icon name="hero-plus" class="w-4 h-4 mr-2" />
              {gettext("New Community")}
            </button>
          <% else %>
            <.link href={Elektrine.Paths.login_path()} class="btn btn-secondary btn-sm w-full">
              <.icon name="hero-user" class="w-4 h-4 mr-2" /> Sign in to Create
            </.link>
          <% end %>

          <div class="space-y-2">
            <button
              phx-click="set_view"
              phx-value-view="feed"
              class={[
                "btn btn-sm min-h-10 px-3 rounded-full w-full justify-start",
                if(@current_view == "feed",
                  do: "btn-secondary",
                  else: "btn-ghost hover:bg-base-200"
                )
              ]}
            >
              <.icon name="hero-rss" class="w-4 h-4 mr-2" /> Community Feed
              <%= if length(@followed_community_posts) > 0 do %>
                <span class="badge badge-xs badge-primary ml-auto">
                  {length(@followed_community_posts)}
                </span>
              <% end %>
            </button>
            <button
              phx-click="set_view"
              phx-value-view="communities"
              class={[
                "btn btn-sm min-h-10 px-3 rounded-full w-full justify-start",
                if(@current_view == "communities",
                  do: "btn-secondary",
                  else: "btn-ghost hover:bg-base-200"
                )
              ]}
            >
              <.icon name="hero-user-group" class="w-4 h-4 mr-2" /> Joined Communities
            </button>
            <button
              phx-click="set_view"
              phx-value-view="my_activity"
              class={[
                "btn btn-sm min-h-10 px-3 rounded-full w-full justify-start",
                if(@current_view == "my_activity",
                  do: "btn-secondary",
                  else: "btn-ghost hover:bg-base-200"
                )
              ]}
            >
              <.icon name="hero-document-text" class="w-4 h-4 mr-2" /> My Activity
              <%= if length(@my_community_posts) > 0 do %>
                <span class="badge badge-xs badge-primary ml-auto">
                  {length(@my_community_posts)}
                </span>
              <% end %>
            </button>
          </div>

          <%= if @current_view == "communities" do %>
            <div class="border-t border-base-300 pt-4 space-y-3">
              <div>
                <h3 class="text-sm font-semibold">Suggested Federated Communities</h3>
                <p class="mt-1 text-xs text-base-content/60 leading-5">
                  Follow a few remote communities to populate your feed. Full-handle lookups also show a richer preview before you follow.
                </p>
              </div>

              <%= if sidebar_federated_suggestions != [] do %>
                <div class="space-y-2.5">
                  <%= for actor <- sidebar_federated_suggestions do %>
                    <div class="rounded-lg border border-base-300 bg-base-200/55 p-3">
                      <div class="flex items-start gap-2.5">
                        <%= if actor.avatar_url do %>
                          <img
                            src={actor.avatar_url}
                            class="w-9 h-9 rounded-lg object-cover flex-shrink-0"
                            alt={actor.username}
                          />
                        <% else %>
                          <div class="w-9 h-9 rounded-lg bg-info/10 text-info flex items-center justify-center flex-shrink-0">
                            <.icon name="hero-globe-alt" class="w-4 h-4" />
                          </div>
                        <% end %>

                        <div class="min-w-0 flex-1">
                          <.link
                            href={community_route(actor)}
                            class="block text-sm font-medium truncate hover:text-secondary transition-colors"
                          >
                            {raw(community_display_name_markup(actor))}
                          </.link>
                          <p class="mt-0.5 text-[11px] text-base-content/50 break-all">
                            {community_address(actor)}
                          </p>
                        </div>
                      </div>

                      <div class="mt-2 flex justify-end">
                        <%= if @current_user do %>
                          <button
                            type="button"
                            id={"sidebar-follow-community-#{actor.id}"}
                            phx-click="follow_remote_group"
                            phx-value-actor_id={actor.id}
                            class="btn btn-secondary btn-xs transition-all duration-150 phx-click-loading:scale-95 phx-click-loading:opacity-80 phx-click-loading:bg-base-200 phx-click-loading:text-base-content"
                          >
                            <span class="phx-click-loading:hidden">Follow</span>
                            <span class="hidden items-center phx-click-loading:inline-flex">
                              <.spinner size="sm" class="mr-1" /> Following...
                            </span>
                          </button>
                        <% else %>
                          <.link href={Elektrine.Paths.login_path()} class="btn btn-ghost btn-xs">
                            Sign in
                          </.link>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-3 text-xs text-base-content/60 leading-5">
                  No suggestions cached yet. Search for a full handle like `!community@server`.
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class={[
      "flex-1 min-w-0 max-w-full",
      if(@current_view == "feed", do: "xl:max-w-4xl")
    ]}>
      <div class="card panel-card overflow-hidden">
        <div class="p-5 sm:p-6 border-b border-base-300">
          <div class="flex flex-col gap-4">
            <%= if @current_view == "communities" do %>
              <div class="space-y-3">
                <.form
                  id="community-search-form"
                  for={%{}}
                  phx-change="search_communities"
                  phx-submit="perform_search"
                  class="flex flex-col lg:flex-row gap-3"
                >
                  <label class="input input-bordered flex items-center gap-2 flex-1 bg-base-100">
                    <.icon name="hero-magnifying-glass" class="w-4 h-4 opacity-60" />
                    <input
                      type="text"
                      name="query"
                      value={@search_query}
                      placeholder={search_placeholder}
                      phx-debounce="250"
                      autocomplete="off"
                    />
                  </label>
                  <div class="flex gap-2">
                    <button type="submit" class="btn btn-secondary">
                      <.icon name="hero-magnifying-glass" class="w-4 h-4 mr-2" /> Search
                    </button>
                    <%= if search_active? do %>
                      <button
                        type="button"
                        phx-click="clear_community_search"
                        data-search-clear="true"
                        class="btn border border-base-300 bg-base-200 hover:bg-base-300"
                      >
                        Clear
                      </button>
                    <% end %>
                  </div>
                </.form>

                <div class="flex flex-wrap gap-2">
                  <%= for {scope, label, icon} <- [
                    {"communities", "Communities", "hero-user-group"},
                    {"posts", "Posts", "hero-document-text"},
                    {"people", "People", "hero-user"}
                  ] do %>
                    <button
                      type="button"
                      phx-click="set_search_scope"
                      phx-value-scope={scope}
                      class={[
                        "btn btn-sm rounded-full gap-2 border border-base-300",
                        if(search_scope == scope,
                          do: "btn-secondary border-secondary",
                          else: "bg-base-200 text-base-content hover:bg-base-300"
                        )
                      ]}
                    >
                      <.icon name={icon} class="w-4 h-4" /> {label}
                      <span class="badge badge-xs badge-outline">{search_counts[scope]}</span>
                    </button>
                  <% end %>
                </div>

                <%= if !search_active? and @current_user && (@recent_searches != [] or @recent_joins != []) do %>
                  <div class={[
                    "grid gap-3",
                    if(@recent_searches != [] and @recent_joins != [], do: "xl:grid-cols-2")
                  ]}>
                    <%= if @recent_searches != [] do %>
                      <div class="rounded-2xl border border-base-300/70 bg-base-200/35 p-4 space-y-3">
                        <div>
                          <h3 class="text-sm font-semibold">Recent Searches</h3>
                          <p class="text-xs text-base-content/60 mt-1">
                            Saved from your latest discovery searches.
                          </p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                          <%= for entry <- @recent_searches do %>
                            <button
                              type="button"
                              phx-click="run_recent_search"
                              phx-value-query={entry["query"]}
                              phx-value-scope={entry["scope"]}
                              class="btn btn-ghost btn-sm rounded-full"
                            >
                              {entry["query"]}
                              <span class="badge badge-xs badge-outline ml-1">
                                {String.capitalize(entry["scope"] || "communities")}
                              </span>
                            </button>
                          <% end %>
                        </div>
                      </div>
                    <% end %>

                    <%= if @recent_joins != [] do %>
                      <div class="rounded-2xl border border-base-300/70 bg-base-200/35 p-4 space-y-3">
                        <div>
                          <h3 class="text-sm font-semibold">Recent Joins</h3>
                          <p class="text-xs text-base-content/60 mt-1">
                            Communities you joined or followed most recently.
                          </p>
                        </div>
                        <div class="grid gap-2.5 lg:grid-cols-2">
                          <%= for join <- @recent_joins do %>
                            <% item = join.item %>
                            <div class="flex items-center justify-between gap-3 rounded-xl border border-base-300/60 bg-base-100/70 px-3 py-2.5 min-w-0">
                              <div class="min-w-0">
                                <.link
                                  href={community_route(item)}
                                  class="block truncate text-sm font-medium hover:text-secondary transition-colors"
                                >
                                  {raw(community_display_name_markup(item))}
                                </.link>
                                <p class="text-[11px] text-base-content/55 break-all">
                                  {community_address(item)}
                                </p>
                              </div>
                              <div class="text-right text-[11px] text-base-content/55 whitespace-nowrap">
                                <div>
                                  {if join.kind == :remote, do: "Followed", else: "Joined"}
                                </div>
                                <div>{Elektrine.Social.time_ago_in_words(join.joined_at)}</div>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <.pill_switcher
                  event="filter_by_category"
                  param="category"
                  active={@selected_category}
                  options={
                    Enum.map(category_pills, fn {value, label} ->
                      %{value: value, label: label}
                    end)
                  }
                />
              </div>
            <% end %>
          </div>
        </div>

        <div class="p-4 sm:p-6">
          <%= if @loading_communities && @has_community_data do %>
            <div class="space-y-4 animate-pulse">
              <%= for _i <- 1..4 do %>
                <div class="card panel-card">
                  <div class="card-body p-4">
                    <div class="flex items-start gap-3">
                      <div class="w-12 h-12 bg-base-300 rounded-lg"></div>
                      <div class="flex-1">
                        <div class="h-4 bg-base-300 rounded w-40 mb-2"></div>
                        <div class="h-3 bg-base-300 rounded w-56 mb-2"></div>
                        <div class="h-3 bg-base-300 rounded w-28"></div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <%= case @current_view do %>
              <% "communities" -> %>
                <div
                  class="space-y-6"
                  phx-hook={if !search_active?, do: "InfiniteScroll", else: nil}
                  id="communities-overview-infinite-scroll"
                  data-offset="500"
                  data-no-more={if(search_active?, do: true, else: @overview_no_more)}
                  data-loading-more={@loading_more}
                >
                  <%= if search_active? do %>
                    <section class="space-y-4">
                      <div class="flex items-center justify-between gap-2">
                        <h2 class="text-xl font-semibold">Search Results</h2>
                        <span class="badge badge-outline">
                          {search_counts[search_scope]} matches
                        </span>
                      </div>

                      <%= if @search_results != [] do %>
                        <%= case search_scope do %>
                          <% "communities" -> %>
                            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                              <%= for result <- @search_results do %>
                                <%= if result.type == :local do %>
                                  <% community = result.community
                                  joined? = MapSet.member?(@joined_community_ids, community.id) %>
                                  <article class="card border border-base-300 bg-base-200/70 hover:border-secondary/40 transition-colors">
                                    <div class="card-body p-4 gap-4">
                                      <div class="flex items-start gap-3">
                                        <div class="w-12 h-12 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center font-semibold text-lg flex-shrink-0">
                                          {String.first(community.name) |> String.upcase()}
                                        </div>
                                        <div class="min-w-0 flex-1">
                                          <div class="flex items-center gap-2 flex-wrap">
                                            <.link
                                              href={community_route(community)}
                                              class="font-semibold truncate hover:text-secondary transition-colors"
                                            >
                                              {community.name}
                                            </.link>
                                            <span class="badge badge-outline badge-sm">
                                              {community_category_label(community)}
                                            </span>
                                            <span class="badge badge-outline badge-sm">
                                              {if community.is_federated_mirror,
                                                do: "Mirror",
                                                else: "Local"}
                                            </span>
                                          </div>
                                          <.link
                                            href={community_route(community)}
                                            class="block text-xs text-base-content/50 mt-1 hover:text-secondary transition-colors"
                                          >
                                            {community_address(community)}
                                          </.link>
                                          <%= if result.description do %>
                                            <.link
                                              href={community_route(community)}
                                              class="block text-sm text-base-content/70 mt-2 line-clamp-2 hover:text-base-content/90 transition-colors"
                                            >
                                              {result.description}
                                            </.link>
                                          <% end %>
                                        </div>
                                      </div>
                                      <div class="flex items-center justify-between gap-3">
                                        <div class="flex flex-wrap gap-3 text-xs text-base-content/60">
                                          <span class="flex items-center gap-1">
                                            <.icon name="hero-users" class="w-3.5 h-3.5" />
                                            {format_compact_number(result.member_count || 0)} members
                                          </span>
                                          <%= if creator = community_creator_markup(community) do %>
                                            <span class="truncate">by {raw(creator)}</span>
                                          <% end %>
                                        </div>
                                        <%= cond do %>
                                          <% joined? -> %>
                                            <span class="badge badge-secondary">Joined</span>
                                          <% @current_user -> %>
                                            <button
                                              type="button"
                                              id={"search-join-community-#{community.id}"}
                                              phx-click="join_community"
                                              phx-value-community_id={community.id}
                                              class="btn btn-secondary btn-sm"
                                            >
                                              Join
                                            </button>
                                          <% true -> %>
                                            <.link
                                              href={Elektrine.Paths.login_path()}
                                              class="btn btn-ghost btn-sm"
                                            >
                                              Sign in
                                            </.link>
                                        <% end %>
                                      </div>
                                    </div>
                                  </article>
                                <% else %>
                                  <% actor = result.remote_actor

                                  following? =
                                    MapSet.member?(
                                      @followed_remote_actor_ids || MapSet.new(),
                                      actor.id
                                    )

                                  result_href = community_route(actor) %>
                                  <article class="card border border-base-300 bg-base-200/70 hover:border-info/40 transition-colors">
                                    <div class="card-body p-4 gap-4">
                                      <div class="flex items-start gap-3">
                                        <%= if actor.avatar_url do %>
                                          <img
                                            src={actor.avatar_url}
                                            class="w-12 h-12 rounded-lg object-cover flex-shrink-0"
                                            alt={actor.username}
                                          />
                                        <% else %>
                                          <div class="w-12 h-12 rounded-lg bg-info/10 text-info flex items-center justify-center flex-shrink-0">
                                            <.icon name="hero-globe-alt" class="w-6 h-6" />
                                          </div>
                                        <% end %>
                                        <div class="min-w-0 flex-1">
                                          <div class="flex items-center gap-2 flex-wrap">
                                            <.link
                                              href={result_href}
                                              class="font-semibold truncate hover:text-info transition-colors"
                                            >
                                              {raw(
                                                ElektrineWeb.HtmlHelpers.render_actor_display_name(
                                                  actor
                                                )
                                              )}
                                            </.link>
                                            <span class="badge badge-outline badge-sm">
                                              {community_category_label(actor)}
                                            </span>
                                            <span class="badge badge-outline badge-sm">
                                              Remote
                                            </span>
                                          </div>
                                          <.link
                                            href={result_href}
                                            class="block text-xs text-base-content/50 mt-1 hover:text-info transition-colors"
                                          >
                                            {community_address(actor)}
                                          </.link>
                                          <%= if result.description do %>
                                            <p class="text-sm text-base-content/70 mt-2 line-clamp-2">
                                              {result.description}
                                            </p>
                                          <% end %>
                                          <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-base-content/55">
                                            <span>
                                              {format_compact_number(
                                                remote_community_followers(actor)
                                              )} followers
                                            </span>
                                            <%= if actor.last_fetched_at do %>
                                              <span>
                                                Previewed {Elektrine.Social.time_ago_in_words(
                                                  actor.last_fetched_at
                                                )}
                                              </span>
                                            <% end %>
                                          </div>
                                        </div>
                                      </div>
                                      <div class="flex items-center justify-between gap-3">
                                        <.link
                                          href={actor.uri}
                                          target="_blank"
                                          rel="noopener noreferrer"
                                          class="btn btn-ghost btn-sm"
                                        >
                                          Preview Remote
                                        </.link>
                                        <%= cond do %>
                                          <% following? -> %>
                                            <span class="badge badge-info">Following</span>
                                          <% @current_user -> %>
                                            <button
                                              type="button"
                                              id={"search-follow-community-#{actor.id}"}
                                              phx-click="follow_remote_group"
                                              phx-value-actor_id={actor.id}
                                              class="btn btn-secondary btn-sm transition-all duration-150 phx-click-loading:scale-95 phx-click-loading:opacity-80 phx-click-loading:bg-base-200 phx-click-loading:text-base-content"
                                            >
                                              <span class="phx-click-loading:hidden">Follow</span>
                                              <span class="hidden items-center phx-click-loading:inline-flex">
                                                <.spinner size="sm" class="mr-1" /> Following...
                                              </span>
                                            </button>
                                          <% true -> %>
                                            <.link
                                              href={Elektrine.Paths.login_path()}
                                              class="btn btn-ghost btn-sm"
                                            >
                                              Sign in
                                            </.link>
                                        <% end %>
                                      </div>
                                    </div>
                                  </article>
                                <% end %>
                              <% end %>
                            </div>
                          <% "posts" -> %>
                            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                              <%= for result <- @search_results do %>
                                <.link
                                  href={result.url}
                                  class="block rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm hover:border-secondary/40 transition-colors"
                                >
                                  <div class="flex min-w-0 items-center gap-2 text-[11px] text-base-content/55">
                                    <span class={[
                                      "badge badge-sm",
                                      if(result.kind == :remote,
                                        do: "badge-outline",
                                        else: "badge-secondary"
                                      )
                                    ]}>
                                      {if result.kind == :remote, do: "Remote", else: "Local"}
                                    </span>
                                    <span class="truncate">{result.community_label}</span>
                                  </div>
                                  <h3 class="mt-3 text-sm font-semibold leading-6 sm:text-base">
                                    {result.title}
                                  </h3>
                                  <%= if result.preview != "" do %>
                                    <p class="mt-2 line-clamp-3 break-all text-sm text-base-content/70 leading-6">
                                      {raw(result.preview)}
                                    </p>
                                  <% end %>
                                  <div class="mt-3 flex items-center justify-between gap-3 text-[11px] text-base-content/55">
                                    <span>{result.metric}</span>
                                    <span>
                                      {Elektrine.Social.time_ago_in_words(result.inserted_at)}
                                    </span>
                                  </div>
                                </.link>
                              <% end %>
                            </div>
                          <% _ -> %>
                            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                              <%= for person <- @search_results do %>
                                <.link
                                  href={person.url}
                                  class="block rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm hover:border-secondary/40 transition-colors"
                                >
                                  <div class="flex items-start gap-3">
                                    <%= if person.avatar_url do %>
                                      <img
                                        src={person.avatar_url}
                                        class="w-12 h-12 rounded-full object-cover flex-shrink-0"
                                        alt={person.username}
                                      />
                                    <% else %>
                                      <div class="w-12 h-12 rounded-full bg-secondary/10 text-secondary flex items-center justify-center font-semibold flex-shrink-0">
                                        {String.first(person.username || "u") |> String.upcase()}
                                      </div>
                                    <% end %>
                                    <div class="min-w-0 flex-1">
                                      <div class="flex items-center gap-2 flex-wrap">
                                        <h3 class="font-semibold truncate">{person.title}</h3>
                                        <span class="badge badge-outline badge-sm">
                                          TL{person.trust_level || 0}
                                        </span>
                                      </div>
                                      <p class="mt-1 text-sm text-base-content/60 truncate">
                                        @{person.handle}
                                      </p>
                                      <p class="mt-2 text-xs text-base-content/55">
                                        Open profile
                                      </p>
                                    </div>
                                  </div>
                                </.link>
                              <% end %>
                            </div>
                        <% end %>
                      <% else %>
                        <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-8 text-center">
                          <.icon
                            name="hero-magnifying-glass"
                            class="w-12 h-12 mx-auto mb-3 opacity-30"
                          />
                          <h3 class="text-lg font-semibold">
                            No {search_scope} matched that search
                          </h3>
                          <p class="text-sm text-base-content/60 mt-2">
                            Try a broader keyword, switch scope, or paste a full handle like `!technology@lemmy.world`.
                          </p>
                        </div>
                      <% end %>
                    </section>
                  <% else %>
                    <section class="space-y-3">
                      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                          <h2 class="text-xl font-semibold">Your Communities</h2>
                        </div>
                        <%= if @current_user && length(@filtered_community_posts) > 0 do %>
                          <button
                            phx-click="set_view"
                            phx-value-view="feed"
                            class="btn btn-ghost btn-sm"
                          >
                            View Feed
                          </button>
                        <% end %>
                      </div>

                      <%= if @current_user do %>
                        <%= if joined_count > 0 do %>
                          <div class="grid gap-3 xl:grid-cols-2">
                            <%= for community <- @filtered_communities do %>
                              <article class="card border border-base-300 bg-base-200/70 hover:border-secondary/40 transition-colors group">
                                <div class="card-body p-3.5">
                                  <div class="flex items-start gap-2.5">
                                    <div class="w-10 h-10 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center font-semibold text-base flex-shrink-0">
                                      {String.first(community.name) |> String.upcase()}
                                    </div>
                                    <div class="min-w-0 flex-1">
                                      <div class="flex items-center gap-1.5 flex-wrap">
                                        <.link
                                          href={community_route(community)}
                                          class="font-semibold truncate text-sm hover:text-secondary transition-colors"
                                        >
                                          {community.name}
                                        </.link>
                                        <span class="badge badge-outline badge-sm">
                                          {community_category_label(community)}
                                        </span>
                                        <span class="badge badge-outline badge-sm">
                                          {if community.is_federated_mirror,
                                            do: "Mirror",
                                            else: "Local"}
                                        </span>
                                      </div>
                                      <.link
                                        href={community_route(community)}
                                        class="block text-[11px] text-base-content/50 mt-0.5 hover:text-secondary transition-colors"
                                      >
                                        {community_address(community)}
                                      </.link>
                                      <%= if community.description do %>
                                        <.link
                                          href={community_route(community)}
                                          class="block text-xs text-base-content/70 mt-1.5 line-clamp-2 leading-5 hover:text-base-content/90 transition-colors"
                                        >
                                          {community.description}
                                        </.link>
                                      <% end %>
                                    </div>
                                  </div>
                                  <div class="flex items-center justify-between gap-2 mt-2.5">
                                    <div class="flex flex-wrap gap-2 text-[11px] text-base-content/60">
                                      <span class="flex items-center gap-1">
                                        <.icon name="hero-users" class="w-3.5 h-3.5" />
                                        {format_compact_number(community.member_count || 0)} members
                                      </span>
                                      <%= if activity = community_activity_text(community) do %>
                                        <span>{activity}</span>
                                      <% end %>
                                    </div>
                                    <button
                                      type="button"
                                      id={"joined-leave-community-#{community.id}"}
                                      phx-click="leave_community"
                                      phx-value-community_id={community.id}
                                      class="btn btn-ghost btn-xs"
                                    >
                                      Leave
                                    </button>
                                  </div>
                                </div>
                              </article>
                            <% end %>

                            <%= for community <- @filtered_remote_communities do %>
                              <article class="card border border-base-300 bg-base-200/70 hover:border-info/40 transition-colors group">
                                <div class="card-body p-3.5">
                                  <div class="flex items-start gap-2.5">
                                    <%= if community.avatar_url do %>
                                      <img
                                        src={community.avatar_url}
                                        class="w-10 h-10 rounded-lg object-cover flex-shrink-0"
                                        alt={community.username}
                                      />
                                    <% else %>
                                      <div class="w-10 h-10 rounded-lg bg-info/10 text-info flex items-center justify-center flex-shrink-0">
                                        <.icon name="hero-globe-alt" class="w-5 h-5" />
                                      </div>
                                    <% end %>
                                    <div class="min-w-0 flex-1">
                                      <div class="flex items-center gap-1.5 flex-wrap">
                                        <.link
                                          href={community_route(community)}
                                          class="font-semibold truncate text-sm hover:text-info transition-colors"
                                        >
                                          {raw(
                                            ElektrineWeb.HtmlHelpers.render_actor_display_name(
                                              community
                                            )
                                          )}
                                        </.link>
                                        <span class="badge badge-outline badge-sm">
                                          {community_category_label(community)}
                                        </span>
                                        <span class="badge badge-outline badge-sm">
                                          Federated
                                        </span>
                                      </div>
                                      <.link
                                        href={community_route(community)}
                                        class="block text-[11px] text-base-content/50 mt-0.5 hover:text-info transition-colors"
                                      >
                                        {community_address(community)}
                                      </.link>
                                      <%= if community.summary do %>
                                        <.link
                                          href={community_route(community)}
                                          class="block text-xs text-base-content/70 mt-1.5 line-clamp-2 leading-5 hover:text-base-content/90 transition-colors"
                                        >
                                          {raw(
                                            ElektrineSocialWeb.Components.Social.PostUtilities.render_content_preview(
                                              community.summary,
                                              community.domain
                                            )
                                          )}
                                        </.link>
                                      <% end %>
                                    </div>
                                  </div>
                                  <div class="flex items-center justify-between gap-2 mt-2.5">
                                    <div class="flex flex-wrap gap-2 text-[11px] text-base-content/60">
                                      <span class="flex items-center gap-1">
                                        <.icon name="hero-globe-alt" class="w-3.5 h-3.5" />
                                        Followed remotely
                                      </span>
                                    </div>
                                    <button
                                      type="button"
                                      id={"joined-unfollow-community-#{community.id}"}
                                      phx-click="unfollow_remote_community"
                                      phx-value-actor_id={community.id}
                                      class="btn btn-ghost btn-xs transition-all duration-150 phx-click-loading:scale-95 phx-click-loading:opacity-80"
                                    >
                                      <span class="phx-click-loading:hidden">Unfollow</span>
                                      <span class="hidden items-center phx-click-loading:inline-flex">
                                        <.spinner size="sm" class="mr-1" /> Unfollowing...
                                      </span>
                                    </button>
                                  </div>
                                </div>
                              </article>
                            <% end %>
                          </div>
                        <% else %>
                          <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-8 text-center">
                            <div class="w-16 h-16 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center mx-auto mb-4">
                              <.icon name="hero-users" class="w-8 h-8" />
                            </div>
                            <h3 class="text-lg font-semibold">
                              You have not joined any communities yet
                            </h3>
                            <p class="text-sm text-base-content/60 mt-2 max-w-md mx-auto">
                              Join a local community or follow a federated one below.
                            </p>
                          </div>
                        <% end %>
                      <% else %>
                        <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-8 text-center">
                          <.icon
                            name="hero-lock-closed"
                            class="w-12 h-12 mx-auto mb-3 opacity-40"
                          />
                          <h3 class="text-lg font-semibold">Sign in to build a joined list</h3>
                          <p class="text-sm text-base-content/60 mt-2">
                            You can still browse discovery and trending discussions below.
                          </p>
                          <.link
                            href={Elektrine.Paths.login_path()}
                            class="btn btn-secondary mt-4"
                          >
                            Sign In
                          </.link>
                        </div>
                      <% end %>
                    </section>

                    <%= if @current_user && @because_you_follow != [] do %>
                      <section class="space-y-3">
                        <div>
                          <h2 class="text-xl font-semibold">Because You Follow...</h2>
                          <p class="text-sm text-base-content/60 mt-1">
                            Suggestions weighted toward the communities you already chose.
                          </p>
                        </div>

                        <div class="grid gap-3 xl:grid-cols-2">
                          <%= for suggestion <- @because_you_follow do %>
                            <% item = suggestion.item %>
                            <article class="rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm">
                              <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                  <div class="badge badge-outline badge-sm">
                                    {community_category_label(item)}
                                  </div>
                                  <.link
                                    href={community_route(item)}
                                    class="mt-2 block text-sm font-semibold hover:text-secondary transition-colors sm:text-base"
                                  >
                                    {raw(community_display_name_markup(item))}
                                  </.link>
                                  <p class="mt-0.5 text-[11px] text-base-content/50 break-all">
                                    {community_address(item)}
                                  </p>
                                  <p class="mt-2 text-xs text-base-content/65 leading-5">
                                    {suggestion.reason}
                                  </p>
                                </div>
                                <span class="badge badge-secondary badge-sm">
                                  {if suggestion.kind == :remote, do: "Remote", else: "Local"}
                                </span>
                              </div>

                              <div class="mt-3 flex items-center justify-between gap-3 text-xs text-base-content/60">
                                <span>
                                  <%= if suggestion.kind == :remote do %>
                                    {format_compact_number(remote_community_followers(item))} followers
                                  <% else %>
                                    {format_compact_number(item.member_count || 0)} members
                                  <% end %>
                                </span>

                                <%= if suggestion.kind == :remote do %>
                                  <%= if MapSet.member?(@followed_remote_actor_ids || MapSet.new(), item.id) do %>
                                    <span class="badge badge-info badge-sm">Following</span>
                                  <% else %>
                                    <button
                                      type="button"
                                      phx-click="follow_remote_group"
                                      phx-value-actor_id={item.id}
                                      class="btn btn-secondary btn-xs"
                                    >
                                      Follow
                                    </button>
                                  <% end %>
                                <% else %>
                                  <%= if MapSet.member?(@joined_community_ids, item.id) do %>
                                    <span class="badge badge-secondary badge-sm">Joined</span>
                                  <% else %>
                                    <button
                                      type="button"
                                      phx-click="join_community"
                                      phx-value-community_id={item.id}
                                      class="btn btn-secondary btn-xs"
                                    >
                                      Join
                                    </button>
                                  <% end %>
                                <% end %>
                              </div>
                            </article>
                          <% end %>
                        </div>
                      </section>
                    <% end %>

                    <section class="space-y-3">
                      <div>
                        <h2 class="text-xl font-semibold">Discover Local Communities</h2>
                      </div>

                      <%= if visible_discover_cards != [] do %>
                        <div class="grid gap-3 xl:grid-cols-2">
                          <%= for card <- visible_discover_cards do %>
                            <% community = card.community
                            joined? = MapSet.member?(@joined_community_ids, community.id) %>
                            <article class="rounded-lg border border-base-300 bg-base-100 p-3.5 shadow-sm">
                              <div class="mb-2 flex flex-wrap items-center gap-1.5">
                                <%= for tag <- discovery_card_tags(card) do %>
                                  <span class="badge badge-secondary badge-sm">{tag}</span>
                                <% end %>
                                <span class="badge badge-outline badge-sm">
                                  {community_category_label(community)}
                                </span>
                              </div>

                              <.link
                                href={community_route(community)}
                                class="block hover:text-secondary transition-colors"
                              >
                                <h3 class="text-sm font-semibold leading-snug break-words text-base-content sm:text-base">
                                  {raw(community_display_name_markup(community))}
                                </h3>
                                <p class="mt-0.5 text-[11px] text-base-content/50 break-all">
                                  {community_address(community)}
                                </p>
                                <%= if community.description do %>
                                  <p class="mt-1.5 text-xs text-base-content/70 line-clamp-2 leading-5 sm:text-sm">
                                    {community.description}
                                  </p>
                                <% end %>
                              </.link>

                              <div class="mt-2.5 flex flex-wrap gap-x-3 gap-y-1.5 text-[11px] text-base-content/60 sm:text-xs">
                                <%= for item <- discovery_card_meta_markup(card) do %>
                                  <span>{raw(item)}</span>
                                <% end %>
                              </div>

                              <div class="mt-3 flex items-center justify-end">
                                <%= if joined? do %>
                                  <span class="badge badge-secondary badge-sm">Joined</span>
                                <% else %>
                                  <%= if @current_user do %>
                                    <button
                                      type="button"
                                      id={"discover-join-community-#{community.id}"}
                                      phx-click="join_community"
                                      phx-value-community_id={community.id}
                                      class="btn btn-secondary btn-xs"
                                    >
                                      Join
                                    </button>
                                  <% else %>
                                    <.link
                                      href={Elektrine.Paths.login_path()}
                                      class="btn btn-ghost btn-xs"
                                    >
                                      Sign in
                                    </.link>
                                  <% end %>
                                <% end %>
                              </div>
                            </article>
                          <% end %>
                        </div>
                      <% else %>
                        <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-6 text-sm text-base-content/60">
                          No new communities matched this category.
                        </div>
                      <% end %>
                    </section>

                    <section class="space-y-3">
                      <div>
                        <h2 class="text-xl font-semibold">Federated Communities</h2>
                      </div>

                      <%= if visible_remote_communities != [] do %>
                        <div class="grid gap-3 xl:grid-cols-2">
                          <%= for actor <- visible_remote_communities do %>
                            <article class="card border border-base-300 bg-base-100 hover:border-info/40 transition-colors">
                              <div class="card-body p-4 gap-4">
                                <.link href={community_route(actor)} class="block">
                                  <div class="flex items-start gap-3">
                                    <%= if actor.avatar_url do %>
                                      <img
                                        src={actor.avatar_url}
                                        class="w-12 h-12 rounded-lg object-cover flex-shrink-0"
                                        alt={actor.username}
                                      />
                                    <% else %>
                                      <div class="w-12 h-12 rounded-lg bg-info/10 text-info flex items-center justify-center flex-shrink-0">
                                        <.icon name="hero-globe-alt" class="w-6 h-6" />
                                      </div>
                                    <% end %>
                                    <div class="min-w-0 flex-1">
                                      <div class="flex items-center gap-2 flex-wrap">
                                        <h3 class="font-semibold truncate">
                                          {raw(community_display_name_markup(actor))}
                                        </h3>
                                        <span class="badge badge-outline badge-sm">
                                          {community_category_label(actor)}
                                        </span>
                                        <span class="badge badge-outline badge-sm">Remote</span>
                                      </div>
                                      <p class="text-xs text-base-content/50 mt-1">
                                        {community_address(actor)}
                                      </p>
                                      <%= if actor.summary do %>
                                        <p class="text-sm text-base-content/70 mt-2 line-clamp-2">
                                          {raw(
                                            PostUtilities.render_content_preview(
                                              actor.summary,
                                              actor.domain
                                            )
                                          )}
                                        </p>
                                      <% end %>
                                    </div>
                                  </div>
                                </.link>
                                <div class="flex items-center justify-between gap-3">
                                  <div class="flex flex-wrap gap-3 text-xs text-base-content/60">
                                    <span class="flex items-center gap-1">
                                      <.icon name="hero-globe-alt" class="w-3.5 h-3.5" />
                                      Federated community
                                    </span>
                                    <span class="flex items-center gap-1">
                                      <.icon name="hero-users" class="w-3.5 h-3.5" />
                                      {format_compact_number(remote_community_followers(actor))} followers
                                    </span>
                                    <%= if creator = community_creator_markup(actor) do %>
                                      <span class="truncate">{raw(creator)}</span>
                                    <% end %>
                                  </div>
                                  <div class="flex items-center gap-2">
                                    <.link
                                      href={actor.uri}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      class="btn btn-ghost btn-sm"
                                    >
                                      Preview
                                    </.link>
                                    <%= if @current_user do %>
                                      <button
                                        type="button"
                                        id={"discover-follow-community-#{actor.id}"}
                                        phx-click="follow_remote_group"
                                        phx-value-actor_id={actor.id}
                                        class="btn btn-secondary btn-sm transition-all duration-150 phx-click-loading:scale-95 phx-click-loading:opacity-80 phx-click-loading:bg-base-200 phx-click-loading:text-base-content"
                                      >
                                        <span class="phx-click-loading:hidden">Follow</span>
                                        <span class="hidden items-center phx-click-loading:inline-flex">
                                          <.spinner size="sm" class="mr-1" /> Following...
                                        </span>
                                      </button>
                                    <% else %>
                                      <.link
                                        href={Elektrine.Paths.login_path()}
                                        class="btn btn-ghost btn-sm"
                                      >
                                        Sign in
                                      </.link>
                                    <% end %>
                                  </div>
                                </div>
                              </div>
                            </article>
                          <% end %>
                        </div>
                      <% else %>
                        <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-6 text-sm text-base-content/60">
                          No federated communities are cached for this category yet.
                        </div>
                      <% end %>
                    </section>

                    <section class="space-y-3">
                      <div>
                        <h2 class="text-xl font-semibold">Active Conversations</h2>
                      </div>

                      <%= if visible_active_thread_cards != [] do %>
                        <div class="grid gap-3 xl:grid-cols-2">
                          <%= for card <- visible_active_thread_cards do %>
                            <% post = card.post %>
                            <.link
                              href={discussion_route(post)}
                              class="block rounded-lg border border-base-300 bg-base-100 p-3.5 shadow-sm hover:border-secondary/40 transition-colors"
                            >
                              <div class="mb-2 flex flex-wrap items-center gap-1.5 text-[11px] text-base-content/60 sm:text-xs">
                                <%= for label <- active_thread_labels(card) do %>
                                  <span class={[
                                    "badge badge-sm",
                                    if(label == "Trending",
                                      do: "badge-secondary",
                                      else: "badge-outline"
                                    )
                                  ]}>
                                    {label}
                                  </span>
                                <% end %>
                                <span>{discussion_community_label(post)}</span>
                              </div>
                              <h4 class="line-clamp-2 text-sm font-semibold sm:text-base">
                                {discussion_title(post)}
                              </h4>
                              <% preview =
                                PostUtilities.render_content_preview(
                                  post.content,
                                  PostUtilities.get_instance_domain(post),
                                  140
                                ) %>
                              <%= if preview != "" do %>
                                <p class="mt-1.5 line-clamp-2 text-xs text-base-content/70 sm:text-sm leading-5">
                                  {raw(preview)}
                                </p>
                              <% end %>
                              <div class="mt-2.5 flex items-center justify-between gap-3 text-[11px] text-base-content/60 sm:text-xs">
                                <span>{active_thread_metric(card)}</span>
                                <span>
                                  {Elektrine.Social.time_ago_in_words(post.inserted_at)}
                                </span>
                              </div>
                            </.link>
                          <% end %>
                        </div>
                      <% else %>
                        <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-6 text-sm text-base-content/60">
                          No active threads yet for this view.
                        </div>
                      <% end %>
                    </section>

                    <%= if !search_active? do %>
                      <div class="py-4 h-24 flex items-center justify-center timeline-load-more-zone">
                        <%= if @overview_no_more do %>
                          <div class="text-sm text-base-content/60">No more overview cards</div>
                        <% else %>
                          <div class="text-center">
                            <button phx-click="load_more_overview" class="btn btn-ghost">
                              Load More
                            </button>
                          </div>
                        <% end %>
                      </div>

                      <div class="h-px w-full" data-infinite-scroll-sentinel aria-hidden="true">
                      </div>
                    <% end %>
                  <% end %>
                </div>
              <% "feed" -> %>
                <div
                  class="space-y-5"
                  phx-hook="InfiniteScroll"
                  id="communities-feed-infinite-scroll"
                  data-offset="500"
                  data-no-more={@no_more_posts}
                  data-loading-more={@loading_more}
                >
                  <section class="border-b border-base-300 pb-5">
                    <div class="w-full sm:max-w-lg">
                      <div
                        class="grid grid-cols-2 sm:grid-cols-4 gap-2"
                        role="tablist"
                        aria-label="Sort community feed"
                      >
                        <button
                          phx-click="set_feed_sort"
                          phx-value-sort="hot"
                          role="tab"
                          aria-selected={@feed_sort == "hot"}
                          class={[
                            "btn btn-sm min-h-10 w-full items-center justify-center rounded-full border border-base-300 leading-none",
                            if(@feed_sort == "hot",
                              do: "btn-secondary border-secondary",
                              else: "bg-base-200 text-base-content hover:bg-base-300"
                            )
                          ]}
                        >
                          Hot
                        </button>
                        <button
                          phx-click="set_feed_sort"
                          phx-value-sort="new"
                          role="tab"
                          aria-selected={@feed_sort == "new"}
                          class={[
                            "btn btn-sm min-h-10 w-full items-center justify-center rounded-full border border-base-300 leading-none",
                            if(@feed_sort == "new",
                              do: "btn-secondary border-secondary",
                              else: "bg-base-200 text-base-content hover:bg-base-300"
                            )
                          ]}
                        >
                          New
                        </button>
                        <button
                          phx-click="set_feed_sort"
                          phx-value-sort="top"
                          role="tab"
                          aria-selected={@feed_sort == "top"}
                          class={[
                            "btn btn-sm min-h-10 w-full items-center justify-center rounded-full border border-base-300 leading-none",
                            if(@feed_sort == "top",
                              do: "btn-secondary border-secondary",
                              else: "bg-base-200 text-base-content hover:bg-base-300"
                            )
                          ]}
                        >
                          Top
                        </button>
                        <button
                          phx-click="set_feed_sort"
                          phx-value-sort="comments"
                          role="tab"
                          aria-selected={@feed_sort == "comments"}
                          class={[
                            "btn btn-sm min-h-10 w-full items-center justify-center rounded-full border border-base-300 leading-none",
                            if(@feed_sort == "comments",
                              do: "btn-secondary border-secondary",
                              else: "bg-base-200 text-base-content hover:bg-base-300"
                            )
                          ]}
                        >
                          Active
                        </button>
                      </div>
                    </div>
                  </section>

                  <%= if @current_user do %>
                    <%= if @loading_communities do %>
                      <div class="space-y-4 animate-pulse" aria-label="Loading community feed">
                        <%= for _i <- 1..4 do %>
                          <article class="card panel-card timeline-post-card border border-base-300 rounded-lg overflow-hidden">
                            <div class="flex">
                              <div class="flex flex-col items-center gap-2 w-12 flex-shrink-0 bg-base-200/50 p-2">
                                <div class="w-6 h-6 rounded bg-base-300"></div>
                                <div class="w-6 h-4 rounded bg-base-300"></div>
                                <div class="w-6 h-6 rounded bg-base-300"></div>
                              </div>
                              <div class="w-20 h-20 flex-shrink-0 m-2 rounded bg-base-300"></div>
                              <div class="flex-1 p-2 min-w-0 space-y-3">
                                <div class="h-4 w-5/6 rounded bg-base-300"></div>
                                <div class="h-3 w-1/3 rounded bg-base-300"></div>
                                <div class="flex gap-2">
                                  <div class="h-3 w-16 rounded bg-base-300"></div>
                                  <div class="h-3 w-20 rounded bg-base-300"></div>
                                  <div class="h-3 w-14 rounded bg-base-300"></div>
                                </div>
                              </div>
                            </div>
                          </article>
                        <% end %>
                      </div>
                    <% else %>
                      <%= if feed_post_count > 0 do %>
                        <div class="space-y-4">
                          <%= for {post, index} <- Enum.with_index(@filtered_community_posts) do %>
                            <.timeline_post
                              post={post}
                              layout={:lemmy}
                              current_user={@current_user}
                              timezone={@timezone}
                              time_format={@time_format}
                              post_interactions={@post_interactions}
                              user_likes={%{}}
                              lemmy_counts={@lemmy_counts}
                              post_reactions_map={@post_reactions}
                              replies={Map.get(@post_replies, post.activitypub_id, [])}
                              reactions={Map.get(@post_reactions, post.id, [])}
                            />
                          <% end %>
                        </div>

                        <%= if length(@followed_community_posts || []) >= 20 do %>
                          <div class="py-4 h-24 flex items-center justify-center timeline-load-more-zone">
                            <%= if @loading_more do %>
                              <div class="h-16 rounded-lg flex items-center justify-center">
                                <div class="flex items-center gap-2 text-sm text-base-content/70">
                                  <.spinner size="sm" /> <span>Loading more posts...</span>
                                </div>
                              </div>
                            <% else %>
                              <%= if @no_more_posts do %>
                                <div class="text-sm text-base-content/60">No more posts</div>
                              <% else %>
                                <div class="text-center">
                                  <button
                                    type="button"
                                    phx-click="load_more_posts"
                                    class="btn btn-ghost"
                                  >
                                    Load More
                                  </button>
                                </div>
                              <% end %>
                            <% end %>
                          </div>
                        <% end %>
                      <% else %>
                        <div class="rounded-2xl border border-dashed border-base-300 bg-base-200/55 p-10 text-center">
                          <.icon name="hero-inbox" class="w-12 h-12 mx-auto mb-3 opacity-40" />
                          <h3 class="text-lg font-semibold">Your community feed is empty</h3>
                          <p class="mx-auto mt-2 max-w-md text-sm text-base-content/60 leading-6">
                            Turn this into a real feed by joining a few communities in {selected_category_label} and pulling in posts from places you actually care about.
                          </p>

                          <%= if joinable_trending_communities != [] do %>
                            <div class="mx-auto mt-5 flex max-w-lg flex-wrap items-center justify-center gap-2">
                              <%= for community <- joinable_trending_communities do %>
                                <span class="badge badge-outline gap-1 px-3 py-3">
                                  <.icon name="hero-fire" class="w-3.5 h-3.5" /> !{community.name}
                                </span>
                              <% end %>
                            </div>
                          <% end %>

                          <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
                            <button
                              phx-click="join_trending_communities"
                              class="btn btn-secondary"
                              disabled={joinable_trending_communities == []}
                            >
                              <.icon name="hero-bolt" class="w-4 h-4 mr-1" />
                              Join Trending in This Category
                            </button>

                            <button
                              phx-click="set_view"
                              phx-value-view="communities"
                              class="btn btn-ghost"
                            >
                              Open Joined Communities
                            </button>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  <% else %>
                    <div class="rounded-2xl border border-dashed border-base-300 bg-base-200/55 p-10 text-center">
                      <.icon name="hero-lock-closed" class="w-12 h-12 mx-auto mb-3 opacity-40" />
                      <h3 class="text-lg font-semibold">Sign in to build a personalized feed</h3>
                      <p class="mx-auto mt-2 max-w-md text-sm text-base-content/60 leading-6">
                        The feed view is for communities you follow, so it starts working once you sign in.
                      </p>
                      <.link href={Elektrine.Paths.login_path()} class="btn btn-secondary mt-5">
                        Sign In
                      </.link>
                    </div>
                  <% end %>

                  <div class="h-px w-full" data-infinite-scroll-sentinel aria-hidden="true"></div>
                </div>
              <% "my_activity" -> %>
                <div class="space-y-4">
                  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
                    <h2 class="text-xl font-semibold">My Community Activity</h2>
                    <span class="badge badge-outline">{length(@my_community_posts)} items</span>
                  </div>

                  <%= if @current_user do %>
                    <%= if length(@my_community_posts) > 0 do %>
                      <%= for post <- @my_community_posts do %>
                        <% local_community = local_community_conversation(post)
                        is_local = not is_nil(local_community)

                        remote_community_uri =
                          get_in(post.media_metadata || %{}, ["community_actor_uri"])

                        remote_community_display =
                          if remote_community_uri,
                            do: String.trim_leading(discussion_community_label(post), "!"),
                            else: nil %>
                        <div class="card shadow-sm border bg-base-200/70 border-base-300 hover:border-base-content/20 transition-colors">
                          <div class="card-body p-4">
                            <div class="flex items-start gap-3">
                              <div class={"w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 " <> if(post.reply_to_id, do: "bg-info/10 text-info", else: "bg-secondary/10 text-secondary")}>
                                <%= if post.reply_to_id do %>
                                  <.icon name="hero-chat-bubble-left" class="w-5 h-5" />
                                <% else %>
                                  <.icon name="hero-document-text" class="w-5 h-5" />
                                <% end %>
                              </div>

                              <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1 flex-wrap text-xs text-base-content/60">
                                  <%= if is_local do %>
                                    <.link
                                      href={~p"/communities/#{local_community.name}"}
                                      class="hover:underline"
                                    >
                                      !{local_community.name}
                                    </.link>
                                  <% else %>
                                    <.link
                                      href={discussion_route(post)}
                                      class="hover:underline flex items-center gap-1"
                                    >
                                      <.icon name="hero-globe-alt" class="w-3 h-3" />
                                      !{remote_community_display}
                                    </.link>
                                  <% end %>
                                  <span>
                                    {Elektrine.Social.time_ago_in_words(post.inserted_at)}
                                  </span>
                                </div>

                                <.link href={discussion_route(post)} class="block">
                                  <h4 class="font-semibold text-sm sm:text-base text-base-content hover:underline line-clamp-2">
                                    {discussion_title(post)}
                                  </h4>
                                </.link>

                                <% preview =
                                  PostUtilities.render_content_preview(
                                    post.content,
                                    PostUtilities.get_instance_domain(post),
                                    140
                                  ) %>
                                <%= if preview != "" do %>
                                  <p class="text-sm opacity-70 line-clamp-2 mt-1">
                                    {raw(preview)}
                                  </p>
                                <% end %>

                                <div class="flex items-center gap-4 mt-2 text-xs opacity-60">
                                  <%= if post.like_count && post.like_count > 0 do %>
                                    <span class="flex items-center gap-1">
                                      <.icon name="hero-arrow-up" class="w-3 h-3" />
                                      {post.like_count}
                                    </span>
                                  <% end %>
                                  <%= if post.reply_count && post.reply_count > 0 do %>
                                    <.link
                                      href={discussion_route(post)}
                                      class="flex items-center gap-1 hover:text-primary hover:underline"
                                    >
                                      <.icon name="hero-chat-bubble-left" class="w-3 h-3" />
                                      {post.reply_count}
                                    </.link>
                                  <% end %>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-10 text-center">
                        <.icon
                          name="hero-document-text"
                          class="w-12 h-12 mx-auto mb-3 opacity-40"
                        />
                        <h3 class="text-lg font-semibold">No activity yet</h3>
                        <p class="text-sm text-base-content/60 mt-2">
                          Your own posts and replies will collect here once you start participating.
                        </p>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="rounded-lg border border-dashed border-base-300 bg-base-200/55 p-10 text-center">
                      <.icon name="hero-lock-closed" class="w-12 h-12 mx-auto mb-3 opacity-40" />
                      <h3 class="text-lg font-semibold">Sign in to track your activity</h3>
                      <p class="text-sm text-base-content/60 mt-2">
                        Your post history is private to your account.
                      </p>
                      <.link href={Elektrine.Paths.login_path()} class="btn btn-secondary mt-4">
                        Sign In
                      </.link>
                    </div>
                  <% end %>
                </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
    
<!-- Right Sidebar - Cross-Context Integration & Suggestions (Hidden on mobile) -->
    <div class="hidden lg:flex w-16 sm:w-20 lg:w-64 xl:w-72 flex-shrink-0 flex-col sticky top-36 self-start max-h-[calc(100vh-11rem)] overflow-y-auto">
      <div class="space-y-6">
        <!-- Quick Post Creator or Login Prompt -->
        <%= if @current_user do %>
          <div class="card panel-card rounded-lg">
            <div class="card-body p-4 space-y-4">
              <h3 class="text-sm font-semibold">Quick Post</h3>

              <%= if @show_quick_post do %>
                <.form for={%{}} phx-submit="create_quick_discussion" class="space-y-2.5">
                  <div class="select select-bordered select-sm w-full">
                    <select
                      name="community_id"
                      required
                    >
                      <option value="">Select community...</option>
                      <%= if !Enum.empty?(@communities) do %>
                        <optgroup label="Local Communities">
                          <%= for community <- @communities do %>
                            <% slug =
                              String.downcase(community.name)
                              |> String.replace(~r/[^a-z0-9]+/, "-") %>
                            <option value={"local:#{community.id}"}>!{slug}</option>
                          <% end %>
                        </optgroup>
                      <% end %>
                      <%= if !Enum.empty?(@followed_remote_communities) do %>
                        <optgroup label="Remote Communities">
                          <%= for actor <- @followed_remote_communities do %>
                            <option value={"remote:#{actor.id}"}>
                              !{actor.username}@{actor.domain}
                            </option>
                          <% end %>
                        </optgroup>
                      <% end %>
                    </select>
                  </div>

                  <input
                    type="text"
                    name="title"
                    placeholder="Post title..."
                    class="input input-bordered input-sm w-full"
                    value={@quick_post_title}
                    required
                  />

                  <textarea
                    name="content"
                    placeholder="What's on your mind?"
                    class="textarea textarea-bordered textarea-sm w-full resize-y overflow-y-auto leading-tight"
                    style="min-height: 2.5rem; max-height: 12rem;"
                    rows="2"
                    phx-hook="AutoExpandTextarea"
                    phx-update="ignore"
                    id="quick-post-textarea"
                  ><%= @quick_post_content %></textarea>

                  <input
                    type="url"
                    name="link_url"
                    placeholder="Optional link URL..."
                    class="input input-bordered input-sm w-full"
                    value={@quick_post_link_url}
                  />
                  
<!-- Media Preview -->
                  <%= if !Enum.empty?(@pending_media_urls) do %>
                    <div class="flex items-center gap-2 rounded-lg bg-base-200 p-2">
                      <.icon name="hero-photo" class="w-4 h-4 text-secondary" />
                      <span class="text-xs">{length(@pending_media_urls)} file(s)</span>
                      <button
                        type="button"
                        phx-click="clear_pending_images"
                        class="btn btn-ghost btn-xs ml-auto"
                      >
                        <.icon name="hero-x-mark" class="w-3 h-3" />
                      </button>
                    </div>
                  <% end %>

                  <div class="flex gap-2">
                    <button
                      type="button"
                      phx-click="open_image_upload"
                      class="btn btn-ghost btn-xs"
                      title="Add media"
                    >
                      <.icon name="hero-photo" class="w-4 h-4" />
                    </button>
                    <button
                      type="button"
                      phx-click="hide_quick_post"
                      class="btn btn-ghost btn-xs flex-1"
                    >
                      {gettext("Cancel")}
                    </button>
                    <button type="submit" class="btn btn-secondary btn-xs flex-1">
                      Post
                    </button>
                  </div>
                </.form>
              <% else %>
                <button phx-click="show_quick_post" class="btn btn-secondary btn-sm w-full">
                  <.icon name="hero-pencil-square" class="w-4 h-4 mr-1" /> Quick Post
                </button>
              <% end %>
            </div>
          </div>
          
<!-- Follow Fediverse Section -->
          <.fediverse_follow
            loading={@remote_user_loading}
            preview={@remote_user_preview}
          />
        <% else %>
          <!-- Login prompt for Quick Discussion -->
          <div class="card panel-card rounded-lg">
            <div class="card-body p-4 space-y-4">
              <h3 class="text-sm font-semibold">Join the Community</h3>
              <.link href={Elektrine.Paths.login_path()} class="btn btn-secondary btn-sm w-full">
                <.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4 mr-1" />
                {gettext("Sign In")}
              </.link>
              <div class="divider text-xs">OR</div>
              <.link href={~p"/register"} class="btn btn-ghost btn-sm w-full">
                <.icon name="hero-user-plus" class="w-4 h-4 mr-1" /> Create Account
              </.link>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%= if @show_create_community do %>
    <div class="modal modal-open">
      <div class="modal-box modal-surface max-w-3xl">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h3 class="font-bold text-2xl">Create Community</h3>
          </div>
          <button
            type="button"
            phx-click="toggle_create_community"
            class="btn btn-ghost btn-sm btn-circle"
          >
            <.icon name="hero-x-mark" class="w-5 h-5" />
          </button>
        </div>

        <.form for={%{}} phx-submit="create_community" class="space-y-4">
          <div class="grid gap-4 md:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
            <div class="space-y-4 rounded-2xl border border-base-300/60 bg-base-200/45 p-4">
              <div>
                <label class="label">
                  <span class="label-text">Community Name</span>
                  <span class="label-text-alt text-xs opacity-70">Letters and numbers only</span>
                </label>
                <input
                  type="text"
                  name="name"
                  placeholder="e.g., ElixirDevelopers"
                  class="input input-bordered w-full"
                  value={@new_community_name}
                  pattern="[a-zA-Z0-9]{2,30}"
                  title="2-30 characters, letters and numbers only (no spaces)"
                  required
                />
                <label class="label">
                  <span class="label-text-alt text-xs">
                    No spaces or special characters allowed
                  </span>
                </label>
              </div>

              <div>
                <label class="label">
                  <span class="label-text">Description</span>
                </label>
                <textarea
                  name="description"
                  placeholder="What is this community about?"
                  class="textarea textarea-bordered w-full resize-y overflow-y-auto leading-tight"
                  style="min-height: 7rem; max-height: 16rem;"
                  rows="4"
                  phx-hook="AutoExpandTextarea"
                  phx-update="ignore"
                  id="community-description-textarea"
                ><%= @new_community_description %></textarea>
              </div>
            </div>

            <div class="rounded-2xl border border-base-300/60 bg-base-200/45 p-4">
              <label class="label">
                <span class="label-text">Category</span>
              </label>
              <div class="select select-bordered w-full h-80">
                <select name="category">
                  <optgroup label="Technology & Science">
                    <option value="tech" selected={@new_community_category == "tech"}>
                      Technology
                    </option>
                    <option
                      value="programming"
                      selected={@new_community_category == "programming"}
                    >
                      Programming
                    </option>
                    <option value="science" selected={@new_community_category == "science"}>
                      Science
                    </option>
                    <option value="space" selected={@new_community_category == "space"}>
                      Space & Astronomy
                    </option>
                    <option value="crypto" selected={@new_community_category == "crypto"}>
                      Cryptocurrency
                    </option>
                  </optgroup>
                  <optgroup label="Entertainment">
                    <option value="gaming" selected={@new_community_category == "gaming"}>
                      Gaming
                    </option>
                    <option value="movies" selected={@new_community_category == "movies"}>
                      Movies
                    </option>
                    <option value="tv" selected={@new_community_category == "tv"}>
                      TV Shows
                    </option>
                    <option value="anime" selected={@new_community_category == "anime"}>
                      Anime & Manga
                    </option>
                    <option value="comics" selected={@new_community_category == "comics"}>
                      Comics
                    </option>
                    <option value="music" selected={@new_community_category == "music"}>
                      Music
                    </option>
                    <option value="books" selected={@new_community_category == "books"}>
                      Books & Literature
                    </option>
                    <option value="comedy" selected={@new_community_category == "comedy"}>
                      Comedy
                    </option>
                    <option value="memes" selected={@new_community_category == "memes"}>
                      Memes
                    </option>
                  </optgroup>
                  <optgroup label="Creative">
                    <option value="art" selected={@new_community_category == "art"}>
                      Art & Illustration
                    </option>
                    <option value="design" selected={@new_community_category == "design"}>
                      Design
                    </option>
                    <option
                      value="photography"
                      selected={@new_community_category == "photography"}
                    >
                      Photography
                    </option>
                    <option value="writing" selected={@new_community_category == "writing"}>
                      Writing
                    </option>
                    <option value="diy" selected={@new_community_category == "diy"}>
                      DIY & How-To
                    </option>
                    <option value="crafts" selected={@new_community_category == "crafts"}>
                      Crafts
                    </option>
                    <option value="fashion" selected={@new_community_category == "fashion"}>
                      Fashion & Style
                    </option>
                  </optgroup>
                  <optgroup label="Lifestyle">
                    <option value="food" selected={@new_community_category == "food"}>
                      Food & Cooking
                    </option>
                    <option value="fitness" selected={@new_community_category == "fitness"}>
                      Fitness & Exercise
                    </option>
                    <option value="health" selected={@new_community_category == "health"}>
                      Health & Wellness
                    </option>
                    <option value="travel" selected={@new_community_category == "travel"}>
                      Travel
                    </option>
                    <option value="pets" selected={@new_community_category == "pets"}>
                      Pets & Animals
                    </option>
                    <option value="nature" selected={@new_community_category == "nature"}>
                      Nature & Outdoors
                    </option>
                    <option value="automotive" selected={@new_community_category == "automotive"}>
                      Cars & Automotive
                    </option>
                    <option value="sports" selected={@new_community_category == "sports"}>
                      Sports
                    </option>
                  </optgroup>
                  <optgroup label="Learning">
                    <option value="education" selected={@new_community_category == "education"}>
                      Education
                    </option>
                    <option value="history" selected={@new_community_category == "history"}>
                      History
                    </option>
                    <option value="philosophy" selected={@new_community_category == "philosophy"}>
                      Philosophy
                    </option>
                    <option value="psychology" selected={@new_community_category == "psychology"}>
                      Psychology
                    </option>
                    <option value="medicine" selected={@new_community_category == "medicine"}>
                      Medicine
                    </option>
                    <option value="law" selected={@new_community_category == "law"}>
                      Law & Legal
                    </option>
                  </optgroup>
                  <optgroup label="Business & Finance">
                    <option value="business" selected={@new_community_category == "business"}>
                      Business
                    </option>
                    <option value="finance" selected={@new_community_category == "finance"}>
                      Finance & Investment
                    </option>
                    <option value="stocks" selected={@new_community_category == "stocks"}>
                      Stocks & Trading
                    </option>
                    <option value="realestate" selected={@new_community_category == "realestate"}>
                      Real Estate
                    </option>
                    <option value="marketing" selected={@new_community_category == "marketing"}>
                      Marketing
                    </option>
                    <option value="career" selected={@new_community_category == "career"}>
                      Career & Jobs
                    </option>
                  </optgroup>
                  <optgroup label="Society">
                    <option value="news" selected={@new_community_category == "news"}>
                      News & Current Events
                    </option>
                    <option value="politics" selected={@new_community_category == "politics"}>
                      Politics
                    </option>
                    <option
                      value="environment"
                      selected={@new_community_category == "environment"}
                    >
                      Environment
                    </option>
                    <option value="energy" selected={@new_community_category == "energy"}>
                      Energy & Sustainability
                    </option>
                    <option
                      value="relationships"
                      selected={@new_community_category == "relationships"}
                    >
                      Relationships
                    </option>
                    <option value="parenting" selected={@new_community_category == "parenting"}>
                      Parenting & Family
                    </option>
                    <option value="religion" selected={@new_community_category == "religion"}>
                      Religion
                    </option>
                    <option
                      value="spirituality"
                      selected={@new_community_category == "spirituality"}
                    >
                      Spirituality
                    </option>
                    <option value="conspiracy" selected={@new_community_category == "conspiracy"}>
                      Conspiracy Theories
                    </option>
                    <option value="paranormal" selected={@new_community_category == "paranormal"}>
                      Paranormal
                    </option>
                  </optgroup>
                  <optgroup label="Other">
                    <option value="general" selected={@new_community_category == "general"}>
                      General Discussion
                    </option>
                  </optgroup>
                </select>
              </div>
            </div>
          </div>

          <div class="modal-action">
            <button
              type="button"
              phx-click="toggle_create_community"
              class="btn btn-ghost"
            >
              {gettext("Cancel")}
            </button>
            <button type="submit" class="btn btn-secondary">
              <.icon name="hero-plus" class="w-4 h-4 mr-1" />
              {gettext("Create Community")}
            </button>
          </div>
        </.form>
      </div>
      <div class="modal-backdrop" phx-click="toggle_create_community"></div>
    </div>
  <% end %>
  
<!-- Media Upload Modal -->
  <%= if @show_image_upload_modal && @current_user do %>
    <div class="modal modal-open">
      <div class="modal-box modal-surface max-w-2xl">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-bold text-lg">Add Media to Post</h3>
          <button
            type="button"
            phx-click="close_image_upload"
            class="btn btn-ghost btn-sm btn-circle"
          >
            <.icon name="hero-x-mark" class="w-5 h-5" />
          </button>
        </div>

        <.form
          for={%{}}
          phx-submit="upload_discussion_images"
          phx-change="validate_discussion_upload"
        >
          <!-- Media Upload Area -->
          <div class="form-control w-full mb-4">
            <label
              for={@uploads.discussion_attachments.ref}
              class="block border-2 border-dashed border-base-300 rounded-lg p-8 text-center cursor-pointer hover:border-secondary transition-colors"
            >
              <.live_file_input upload={@uploads.discussion_attachments} class="hidden" />
              <%= if Enum.empty?(@uploads.discussion_attachments.entries) do %>
                <.icon name="hero-photo" class="w-12 h-12 mx-auto opacity-30 mb-2" />
                <p class="text-sm opacity-70">Click to upload or drag and drop</p>
                <p class="text-xs opacity-50 mt-1">Images: JPG, PNG, GIF, WEBP</p>
                <p class="text-xs opacity-50">Videos: MP4, WEBM, OGV, MOV | Audio: MP3, WAV</p>
                <p class="text-xs opacity-50 mt-1">Up to 4 files, 50MB each</p>
              <% else %>
                <div class="space-y-4">
                  <%= for {entry, idx} <- Enum.with_index(@uploads.discussion_attachments.entries) do %>
                    <div class="border border-base-300 rounded-lg p-3">
                      <div class="flex gap-3">
                        <.live_img_preview
                          entry={entry}
                          class="rounded-lg w-24 h-24 object-cover flex-shrink-0"
                        />
                        <div class="flex-1 min-w-0">
                          <div class="text-sm font-medium mb-2 truncate">{entry.client_name}</div>
                          <input
                            type="text"
                            name={"alt_text_#{idx}"}
                            placeholder="Add description (optional)"
                            class="input input-bordered input-sm w-full"
                            maxlength="1000"
                          />
                          <div class="text-xs opacity-60 mt-1">Helps visually impaired users</div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </label>
            <%= for entry <- @uploads.discussion_attachments.entries do %>
              <%= for err <- upload_errors(@uploads.discussion_attachments, entry) do %>
                <div class="alert alert-error mt-2">
                  <span class="text-sm">{error_to_string(err)}</span>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="modal-action">
            <button type="button" class="btn" phx-click="close_image_upload">Cancel</button>
            <button
              type="submit"
              class="btn btn-secondary"
              disabled={Enum.empty?(@uploads.discussion_attachments.entries)}
            >
              <.icon name="hero-check" class="w-4 h-4 mr-1" /> Add Media
            </button>
          </div>
        </.form>
      </div>
      <div class="modal-backdrop" phx-click="close_image_upload"></div>
    </div>
  <% end %>

  <.image_modal
    show={@show_image_modal}
    image_url={@modal_image_url}
    images={@modal_images}
    image_index={@modal_image_index}
    post={@modal_post}
    timezone={@timezone}
    time_format={@time_format}
    current_user={@current_user}
    is_liked={@modal_post && Map.get(assigns[:user_likes] || %{}, @modal_post.id, false)}
    like_count={(@modal_post && @modal_post.like_count) || 0}
  />
  
<!-- Scroll to Top Button -->
  <button
    id="scroll-to-top"
    phx-hook="ScrollToTop"
    class="fixed bottom-6 right-6 z-50 btn btn-circle btn-primary shadow-lg opacity-0 pointer-events-none transition-all duration-300"
    aria-label="Scroll to top"
  >
    <.icon name="hero-chevron-up" class="w-5 h-5" />
  </button>
</div>
