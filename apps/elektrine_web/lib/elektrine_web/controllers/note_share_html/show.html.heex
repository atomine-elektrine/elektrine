<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{@page_title} • Elektrine</title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <main class="mx-auto flex min-h-screen w-full max-w-5xl items-start px-4 py-10 sm:px-6 lg:px-8">
      <article class="card panel-card mx-auto w-full max-w-3xl overflow-hidden">
        <div class="border-b border-base-300/60 px-5 py-5 sm:px-6 sm:py-6">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="space-y-2">
              <div class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
                Shared Note
              </div>
              <h1 class="text-2xl font-semibold tracking-tight text-base-content sm:text-3xl">
                <%= if @note.title in [nil, ""] do %>
                  Untitled note
                <% else %>
                  {@note.title}
                <% end %>
              </h1>
            </div>

            <a href="/" class="btn btn-ghost btn-sm h-9 min-h-9">Elektrine</a>
          </div>
        </div>

        <div class="px-5 py-5 sm:px-6 sm:py-6">
          <pre class="overflow-x-auto whitespace-pre-wrap break-words font-sans text-sm leading-7 text-base-content sm:text-[0.95rem]"><%= @note.body %></pre>
        </div>
      </article>
    </main>
  </body>
</html>
