{
  "manifest_version": 3,
  "name": "Elektrine Nerve",
  "version": "0.1.0",
  "description": "Autofill, capture pages, and manage Elektrine Nerve entries from the browser toolbar.",
  "permissions": ["storage", "tabs", "activeTab", "clipboardWrite", "identity", "contextMenus"],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://[::1]/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nerve@elektrine.app",
      "strict_min_version": "131.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Elektrine Nerve",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://[::1]/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
