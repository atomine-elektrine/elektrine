{
	email {$ACME_EMAIL}
	storage file_system /data/caddy

	on_demand_tls {
		ask {$CADDY_ASK_URL}/{$CADDY_EDGE_API_KEY}
	}

	auto_https disable_redirects

	servers :443 {
		listener_wrappers {
			proxy_protocol {
				timeout 2s
				allow 172.16.0.0/12
				fallback_policy skip
			}
			tls
		}
	}

	servers :80 {
		listener_wrappers {
			proxy_protocol {
				timeout 2s
				allow 172.16.0.0/12
				fallback_policy skip
			}
		}
	}
}

(admin_netbird_gate) {
	@admin_off_vpn {
		host {$CADDY_ADMIN_HOST:admin.elektrine.com}
		not remote_ip {$NETBIRD_ALLOWED_CIDRS:192.0.2.0/32}
	}
	respond @admin_off_vpn "Not Found" 404
}

# elektrine:media:start
{$CADDY_MEDIA_HOST:media.elektrine.com} {
	tls {$CADDY_MANAGED_SITE_1_CERT_PATH} {$CADDY_MANAGED_SITE_1_KEY_PATH}
	@private_media path /attachments/* /chat-attachments/* /discussion-attachments/* /email-attachments/* /gallery-attachments/* /timeline-attachments/* /voice-messages/*
	respond @private_media "Not Found" 404

	rewrite * /{$S3_BUCKET_NAME}{uri}

	reverse_proxy {$CADDY_MEDIA_UPSTREAM:magpie:8090} {
		header_up Host {upstream_hostport}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
		header_up X-Real-IP {client_ip}
	}
}
# elektrine:media:end

{$CADDY_MANAGED_SITE_1} {
	tls {$CADDY_MANAGED_SITE_1_CERT_PATH} {$CADDY_MANAGED_SITE_1_KEY_PATH}
	header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	import admin_netbird_gate

	reverse_proxy {$ORIGIN_UPSTREAM:app:8080} {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
		header_up X-Real-IP {client_ip}
	}
}

# elektrine:site2:start
{$CADDY_MANAGED_SITE_2} {
	tls {$CADDY_MANAGED_SITE_2_CERT_PATH} {$CADDY_MANAGED_SITE_2_KEY_PATH}
	header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	import admin_netbird_gate

	reverse_proxy {$ORIGIN_UPSTREAM:app:8080} {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
		header_up X-Real-IP {client_ip}
	}
}
# elektrine:site2:end

https:// {
	tls {
		on_demand
	}

	header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	import admin_netbird_gate

	reverse_proxy {$ORIGIN_UPSTREAM:app:8080} {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
		header_up X-Real-IP {client_ip}
	}
}

:80 {
	import admin_netbird_gate
	redir https://{host}{uri} 308
}
