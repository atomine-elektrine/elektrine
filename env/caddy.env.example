# Caddy edge profile
# Merge into .env.production when using the Docker caddy profile.

# ACME account email used for certificate issuance.
ACME_EMAIL=admin@example.com

# Shared-secret auth for Caddy's internal on-demand TLS allow request.
# Defaults to PHOENIX_API_KEY in the Docker compose templates, but setting it
# explicitly avoids silent mismatches when environments drift.
# CADDY_EDGE_API_KEY=

# Optional alternate Caddyfile for externally managed wildcard certificates.
# Normally inferred automatically when CADDY_MANAGED_SITE_* contains a wildcard
# and matching cert/key paths are set.
# CADDY_CONFIG_PATH=../caddy/Caddyfile.baremetal.wildcard-external

# Optional DNS-01 automation for wildcard certificates. Run
# scripts/acme/issue_elektrine_wildcard_cert.sh. The script
# reads .env.production, uses PHOENIX_API_KEY/CADDY_EDGE_API_KEY for the internal
# DNS challenge endpoint, and Oban can run renewals through acme.sh.
# ACME_WILDCARD_RENEWAL_ENABLED=true
# ACME_HOME=/data/acme.sh
# ACME_RENEW_COMMAND=/data/acme.sh/acme.sh --cron --home /data/acme.sh

# Host directory bind-mounted into the Caddy container for certificate access.
# CADDY_TLS_MOUNT_DIR=/opt/elektrine/certs

# Certificate paths inside the Caddy container when using external cert mode.
# CADDY_MANAGED_SITE_1_CERT_PATH=/opt/elektrine/certs/example.com.fullchain.pem
# CADDY_MANAGED_SITE_1_KEY_PATH=/opt/elektrine/certs/example.com.key.pem
# CADDY_MANAGED_SITE_2_CERT_PATH=/opt/elektrine/certs/alt.example.net.fullchain.pem
# CADDY_MANAGED_SITE_2_KEY_PATH=/opt/elektrine/certs/alt.example.net.key.pem

# Space-separated hostnames covered by the first managed certificate block.
# Include wildcard hosts only when using external cert mode. The Elektrine ACME
# script installs certs at the default paths below.
CADDY_MANAGED_SITE_1="example.com *.example.com mail.example.com imap.example.com pop.example.com smtp.example.com"

# Optional second managed certificate block for a second zone.
CADDY_MANAGED_SITE_2="alt.example.net mail.alt.example.net imap.alt.example.net pop.alt.example.net smtp.alt.example.net"

# Reverse proxy target for Caddy.
CADDY_ORIGIN_UPSTREAM=app:8080
