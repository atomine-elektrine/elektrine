# Elektrine environment example
# Copy to .env and adjust values for your environment.
#
# Active assignments below are safe for local development.
# Production-only and optional settings stay commented so they remain unset
# until you intentionally enable them.

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_NAME=elektrine_dev
# PGUSER / PGPASSWORD / PGHOST / PGDATABASE and POSTGRES_* also work as fallbacks.

PRIMARY_DOMAIN=localhost
# Optional overrides for split-domain setups:
# PHX_HOST=localhost
# EMAIL_DOMAIN=localhost
# SUPPORTED_DOMAINS=localhost
# PROFILE_BASE_DOMAINS=localhost
# INSTANCE_DOMAIN=localhost
# EMAIL_SUPPORTED_DOMAINS is still accepted as a legacy alias.

USE_LOCAL_EMAIL=true
EMAIL_SERVICE=local
EMAIL_AUTO_SUPPRESSION=true
HARAKA_ASYNC_INGEST=true

TIMELINE_REMOTE_ENRICHMENT=false

# =============================================================================
# MESSAGING FEDERATION
# =============================================================================

MESSAGING_FEDERATION_ENABLED=true
MESSAGING_FEDERATION_IDENTITY_KEY_ID=default
MESSAGING_FEDERATION_OFFICIAL_RELAY_OPERATOR=Community-operated
MESSAGING_FEDERATION_OFFICIAL_RELAYS_JSON='[]'
MESSAGING_FEDERATION_PEERS_JSON='[]'

# Optional identity material for signed federation.
# MESSAGING_FEDERATION_IDENTITY_KEYS_JSON='[{"id":"default","secret":"replace-me","active_outbound":true}]'
# MESSAGING_FEDERATION_IDENTITY_SHARED_SECRET=replace-me

# Optional federation runtime tuning.
# MESSAGING_FEDERATION_ALLOW_INSECURE_HTTP_TRANSPORT=false
# MESSAGING_FEDERATION_DELIVERY_CONCURRENCY=6
# MESSAGING_FEDERATION_DELIVERY_TIMEOUT_MS=12000
# MESSAGING_FEDERATION_OUTBOX_MAX_ATTEMPTS=8
# MESSAGING_FEDERATION_OUTBOX_BASE_BACKOFF_SECONDS=5
# MESSAGING_FEDERATION_EVENT_RETENTION_DAYS=14
# MESSAGING_FEDERATION_OUTBOX_RETENTION_DAYS=30
# MESSAGING_FEDERATION_CLOCK_SKEW_SECONDS=300
# MESSAGING_FEDERATION_CONFORMANCE_CORE_PASSED=true
# MESSAGING_FEDERATION_CONFORMANCE_EXT_ROLES_PASSED=true
# MESSAGING_FEDERATION_CONFORMANCE_EXT_PERMISSIONS_PASSED=true
# MESSAGING_FEDERATION_CONFORMANCE_EXT_THREADS_PASSED=true
# MESSAGING_FEDERATION_CONFORMANCE_EXT_PRESENCE_PASSED=true
# MESSAGING_FEDERATION_CONFORMANCE_EXT_MODERATION_PASSED=true

# =============================================================================
# BLUESKY
# =============================================================================

BLUESKY_ENABLED=false
BLUESKY_INBOUND_ENABLED=false
BLUESKY_SERVICE_URL=https://bsky.social
BLUESKY_TIMEOUT_MS=12000
BLUESKY_MAX_CHARS=300
BLUESKY_INBOUND_LIMIT=50

BLUESKY_MANAGED_ENABLED=false

# Required only when managed PDS mode is enabled.
# BLUESKY_MANAGED_SERVICE_URL=http://localhost:3000
# In Docker/self-hosted production, prefer the internal service URL:
# BLUESKY_MANAGED_SERVICE_URL=http://bluesky_pds:3000
# BLUESKY_MANAGED_DOMAIN=bsky.local
# BLUESKY_MANAGED_ADMIN_PASSWORD=replace-me

# Docker Compose sidecar settings for the bundled PDS service.
# BLUESKY_PDS_PORT=3000
# BLUESKY_PDS_JWT_SECRET=replace-me
# BLUESKY_PDS_ROTATION_KEY_HEX=replace-me

# =============================================================================
# RELEASE / PRODUCTION BASICS
# =============================================================================

# Required for releases.
# PHX_SERVER=true
# PORT=4000
# DATABASE_URL=ecto://elektrine:change-me@localhost/elektrine_prod
# SECRET_KEY_BASE=replace-with-mix-phx-gen-secret

# Optional release overrides.
# ACTIVITYPUB_MOVE_FROM_DOMAIN=old.example.com
# SESSION_SIGNING_SALT=replace-with-unique-random-string
# SESSION_ENCRYPTION_SALT=replace-with-unique-random-string
# SESSION_COOKIE_SECURE=true
# FORCE_SSL=true
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16
# DNS_CLUSTER_QUERY=elektrine.internal
# ECTO_IPV6=true

# Admin elevation / passkey policy.
# ADMIN_REQUIRE_PASSKEY=true
# ADMIN_ACCESS_TTL_SECONDS=900
# ADMIN_ELEVATION_TTL_SECONDS=300
# ADMIN_ACTION_GRANT_TTL_SECONDS=90
# ADMIN_INTENT_TTL_SECONDS=180
# ADMIN_ACTION_REPLAY_TTL_SECONDS=600

# =============================================================================
# DATABASE RUNTIME TUNING
# =============================================================================

# POOL_SIZE=20
# DATABASE_SSL_ENABLED=true
# DATABASE_SSL_VERIFY=peer
# DATABASE_SSL_CACERTFILE=/etc/ssl/certs/ca-certificates.crt
# DATABASE_SSL_SERVER_NAME=db.example.com
# DB_PREPARE=named
# DB_APPLICATION_NAME=elektrine
# DB_QUEUE_TARGET_MS=2000
# DB_QUEUE_INTERVAL_MS=5000
# DB_TIMEOUT_MS=30000
# DB_POOL_TIMEOUT_MS=15000
# DB_CONNECT_TIMEOUT_MS=15000
# MIGRATION_POOL_SIZE=2
# MIGRATION_TIMEOUT_MS=120000
# MIGRATION_POOL_TIMEOUT_MS=60000
# MIGRATION_CONNECT_TIMEOUT_MS=60000
# MIGRATION_DB_RETRIES=30
# MIGRATION_RETRY_DELAY_MS=3000
# MIGRATION_DATABASE_URL=ecto://elektrine:change-me@localhost/elektrine_prod

# ActivityPub inbox rate limiting.
# AP_INBOX_MAX_PER_IP_PER_MINUTE=20
# AP_INBOX_MAX_PER_DOMAIN_PER_MINUTE=40
# AP_INBOX_MAX_GLOBAL_PER_SECOND=8

# =============================================================================
# ENCRYPTION
# =============================================================================

# Set all three to enable encrypted email storage in production.
# If they stay unset in prod, email encryption is disabled.
# ENCRYPTION_MASTER_SECRET=replace-me
# ENCRYPTION_KEY_SALT=replace-me
# ENCRYPTION_SEARCH_SALT=replace-me

# =============================================================================
# HARAKA / EMAIL INTEGRATION
# =============================================================================

# Set EMAIL_SERVICE=haraka to enable the Haraka adapter.
# HARAKA_BASE_URL=http://localhost:2525

# Outbound auth: prefer HARAKA_HTTP_API_KEY.
# HARAKA_HTTP_API_KEY=
# HARAKA_OUTBOUND_API_KEY=
# HARAKA_API_KEY=

# Inbound auth: prefer PHOENIX_API_KEY.
# PHOENIX_API_KEY=
# HARAKA_INBOUND_API_KEY=

# Optional request signing / receiver protection.
# HARAKA_INTERNAL_SIGNING_SECRET=
# EMAIL_RECEIVER_WEBHOOK_SECRET=

# =============================================================================
# CUSTOM DOMAIN EMAIL SETTINGS
# =============================================================================

# CUSTOM_DOMAIN_MX_HOST=mail.example.com
# CUSTOM_DOMAIN_MX_PRIORITY=10
# CUSTOM_DOMAIN_SPF_INCLUDE=_spf.example.com
# CUSTOM_DOMAIN_DKIM_SELECTOR=default
# CUSTOM_DOMAIN_DKIM_SYNC_ENABLED=true
# CUSTOM_DOMAIN_HARAKA_BASE_URL=http://localhost:2525
# CUSTOM_DOMAIN_HARAKA_API_KEY=
# CUSTOM_DOMAIN_HARAKA_TIMEOUT_MS=10000
# CUSTOM_DOMAIN_HARAKA_DKIM_PATH=/api/v1/dkim/domains
# CUSTOM_DOMAIN_DMARC_POLICY=quarantine
# CUSTOM_DOMAIN_DMARC_RUA=mailto:dmarc@example.com
# CUSTOM_DOMAIN_DMARC_ADKIM=s
# CUSTOM_DOMAIN_DMARC_ASPF=s

# =============================================================================
# STORAGE
# =============================================================================

# Uncomment to use Cloudflare R2 / S3-compatible uploads instead of local storage.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# GIPHY_API_KEY=
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# =============================================================================
# NETWORK / INTERNAL APIS
# =============================================================================

# MATRIX_SERVER_DELEGATION=matrix.example.com:8448
# MATRIX_CLIENT_BASE_URL=https://matrix.example.com
# MATRIX_INTERNAL_API_KEY=
# MONGOOSEIM_API_KEY=
# VPN_FLEET_REGISTRATION_KEY=

# =============================================================================
# ONION / TOR DEPLOYMENT
# =============================================================================

# ONION_TLS_ENABLED=true
# ONION_TLS_PORT=8443
# ONION_TLS_CERTFILE=/data/certs/live/onion-cert.pem
# ONION_TLS_KEYFILE=/data/certs/live/onion-key.pem

# Optional hidden-service identity backup/restore for deployments.
# ONION_HOST=
# ONION_HS_SECRET_KEY_B64=
# ONION_HS_PUBLIC_KEY_B64=
