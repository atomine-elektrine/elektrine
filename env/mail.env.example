# Mail add-on profile
# Requires the email module plus a separate elektrine-haraka deployment.
# The two deployments can still live on the same bare-metal server.

ELEKTRINE_RELEASE_MODULES=chat,social,email,vault
ELEKTRINE_ENABLED_MODULES=chat,social,email,vault

# Typical same-server split:
# PRIMARY_DOMAIN=example.com
# PHX_HOST=example.com
# EMAIL_DOMAIN=example.com
# SUPPORTED_DOMAINS=example.com
#
# EMAIL_DOMAIN is the mailbox domain used for addresses like user@example.com.
# It is usually the main domain, not the Haraka host. Keep the mail server host in
# HARAKA_BASE_URL and CUSTOM_DOMAIN_MX_HOST instead.

EMAIL_SERVICE=haraka
HARAKA_BASE_URL=https://mail.example.com
# Same-server bare-metal option:
# HARAKA_BASE_URL=http://host.docker.internal:18080

# If you use Elektrine's built-in mail protocol edge instead of Haraka,
# enable the email Docker profile and provide a TLS cert/key for nginx stream.
# DOCKER_PROFILES=caddy email
# MAIL_TLS_CERT_PATH=/opt/elektrine/certs/mail.crt
# MAIL_TLS_KEY_PATH=/opt/elektrine/certs/mail.key
# MAIL_TLS_MOUNT_DIR=/opt/elektrine/certs

# Outbound auth: prefer HARAKA_HTTP_API_KEY.
HARAKA_HTTP_API_KEY=
# HARAKA_OUTBOUND_API_KEY=
# HARAKA_API_KEY=

# Inbound auth: prefer PHOENIX_API_KEY.
PHOENIX_API_KEY=
# HARAKA_INBOUND_API_KEY=

# Optional request signing / receiver protection.
# HARAKA_INTERNAL_SIGNING_SECRET=
# EMAIL_RECEIVER_WEBHOOK_SECRET=

# Optional custom domain mail settings.
# CUSTOM_DOMAIN_MX_HOST=mail.example.com
# CUSTOM_DOMAIN_MX_PRIORITY=10
# CUSTOM_DOMAIN_SPF_INCLUDE=_spf.example.com
# CUSTOM_DOMAIN_DKIM_SELECTOR=default
# CUSTOM_DOMAIN_DKIM_SYNC_ENABLED=true
# CUSTOM_DOMAIN_HARAKA_BASE_URL=https://mail.example.com
# CUSTOM_DOMAIN_HARAKA_API_KEY=
# CUSTOM_DOMAIN_HARAKA_TIMEOUT_MS=10000
# CUSTOM_DOMAIN_HARAKA_DKIM_PATH=/api/v1/dkim/domains
# CUSTOM_DOMAIN_DMARC_POLICY=quarantine
# CUSTOM_DOMAIN_DMARC_RUA=mailto:dmarc@example.com
# CUSTOM_DOMAIN_DMARC_ADKIM=s
# CUSTOM_DOMAIN_DMARC_ASPF=s
