# Bluesky managed PDS preset
# self_host.sh adds the Docker bluesky profile and generates PDS secrets when
# they are not already set.

BLUESKY_MANAGED_ENABLED=true
BLUESKY_MANAGED_SERVICE_URL=http://bluesky_pds:3000

# Set this to the managed PDS hostname before production use.
# BLUESKY_MANAGED_DOMAIN=bsky.example.com
# BLUESKY_PDS_PORT=3000
