# DNS preset
# self_host.sh adds the dns module and Docker dns profile.

# Authoritative DNS is enabled by the dns profile. Recursive DNS is off by
# default; enable only when this host should also answer recursive queries.
# DNS_RECURSIVE_ENABLED=false

# Optional branding overrides. Defaults are ns1.<PRIMARY_DOMAIN>,
# ns2.<PRIMARY_DOMAIN>, and admin.<PRIMARY_DOMAIN>.
# DNS_NAMESERVERS=ns1.example.com,ns2.example.com
# DNS_SOA_RNAME=admin.example.com
