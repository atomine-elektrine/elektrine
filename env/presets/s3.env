# S3/Magpie storage preset
# Fill in credentials before deploying. Leave these unset to keep local uploads.

# S3_ACCESS_KEY_ID=<provider-access-key-id>
# S3_SECRET_ACCESS_KEY=<provider-secret-access-key>
# S3_ENDPOINT=magpie:8090
# S3_BUCKET_NAME=elektrine-uploads
# S3_PUBLIC_URL=https://media.example.com
# S3_SCHEME=http://
# S3_PORT=8090

# Optional Caddy media route when S3_PUBLIC_URL is media.<PRIMARY_DOMAIN>.
# CADDY_MEDIA_HOST=media.example.com
# CADDY_MEDIA_UPSTREAM=magpie:8090
# MAGPIE_DOCKER_NETWORK=elektrine-magpie-shared
