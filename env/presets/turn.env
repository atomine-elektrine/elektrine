# TURN preset
# self_host.sh adds the Docker turn profile and generates TURN_SHARED_SECRET
# when it is not already set.

# TURN_HOST defaults to PRIMARY_DOMAIN.
# TURN_HOST=turn.example.com
# TURN_PORT=3478
# TURN_MIN_PORT=49160
# TURN_MAX_PORT=49200

# Required only for NAT or multi-interface hosts.
# TURN_EXTERNAL_IP=203.0.113.10
# TURN_RELAY_IP=10.0.0.5
