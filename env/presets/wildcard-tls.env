# Wildcard TLS preset
# Requires the caddy profile and authoritative DNS challenge support.
# self_host.sh sets TLS_MODE=letsencrypt-dns when enabling this preset.

CADDY_MANAGED_SITE_1="$PRIMARY_DOMAIN *.$PRIMARY_DOMAIN"
CADDY_TLS_MOUNT_DIR=/opt/elektrine/certs
CADDY_MANAGED_SITE_1_CERT_PATH=/opt/elektrine/certs/$PRIMARY_DOMAIN.fullchain.pem
CADDY_MANAGED_SITE_1_KEY_PATH=/opt/elektrine/certs/$PRIMARY_DOMAIN.key.pem
ACME_WILDCARD_RENEWAL_ENABLED=true
ACME_HOME=/data/acme.sh

# Optional: add mail-related names to the same cert.
# CADDY_MANAGED_SITE_1="$PRIMARY_DOMAIN *.$PRIMARY_DOMAIN mail.$PRIMARY_DOMAIN imap.$PRIMARY_DOMAIN pop.$PRIMARY_DOMAIN smtp.$PRIMARY_DOMAIN"
