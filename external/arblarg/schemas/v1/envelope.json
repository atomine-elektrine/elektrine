{
  "$id": "arblarg://schemas/1.0/envelope",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "event_id": {
      "minLength": 1,
      "type": "string"
    },
    "event_type": {
      "enum": [
        "urn:arblarg:ext:bootstrap:1#server.upsert",
        "message.create",
        "message.update",
        "message.delete",
        "reaction.add",
        "reaction.remove",
        "read.cursor",
        "membership.upsert",
        "invite.upsert",
        "ban.upsert",
        "urn:arblarg:ext:roles:1#role.upsert",
        "urn:arblarg:ext:roles:1#role.assignment.upsert",
        "urn:arblarg:ext:permissions:1#overwrite.upsert",
        "urn:arblarg:ext:threads:1#thread.upsert",
        "urn:arblarg:ext:threads:1#thread.archive",
        "urn:arblarg:ext:presence:1#presence.update",
        "urn:arblarg:ext:presence:1#typing.start",
        "urn:arblarg:ext:presence:1#typing.stop",
        "urn:arblarg:ext:moderation:1#action.recorded",
        "urn:arblarg:ext:dm:1#message.create"
      ],
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "type": "string"
    },
    "origin_domain": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "protocol": {
      "const": "arblarg",
      "type": "string"
    },
    "protocol_id": {
      "const": "arblarg",
      "type": "string"
    },
    "protocol_version": {
      "const": "1.0",
      "type": "string"
    },
    "sent_at": {
      "format": "date-time",
      "type": "string"
    },
    "sequence": {
      "minimum": 1,
      "type": "integer"
    },
    "signature": {
      "properties": {
        "algorithm": {
          "const": "ed25519",
          "type": "string"
        },
        "key_id": {
          "minLength": 1,
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "type": "object"
    },
    "stream_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "protocol",
    "protocol_id",
    "protocol_version",
    "event_type",
    "event_id",
    "origin_domain",
    "stream_id",
    "sequence",
    "sent_at",
    "idempotency_key",
    "payload",
    "signature"
  ],
  "title": "Arblarg Event Envelope",
  "type": "object"
}
