{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arbp://schemas/1.0/permission.overwrite.upsert",
  "title": "Arblarg permission.overwrite.upsert payload",
  "type": "object",
  "required": [
    "server",
    "channel",
    "overwrite"
  ],
  "properties": {
    "server": {
      "type": "object"
    },
    "channel": {
      "type": "object"
    },
    "overwrite": {
      "type": "object",
      "required": [
        "id",
        "target",
        "allow",
        "deny"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "object",
          "required": [
            "type",
            "id"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "role",
                "member"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
