{
  "$id": "arblarg://schemas/1.0/presence.update",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "channel": {
      "type": "object"
    },
    "presence": {
      "properties": {
        "activities": {
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "actor": {
          "properties": {
            "avatar_url": {
              "type": "string"
            },
            "display_name": {
              "type": "string"
            },
            "domain": {
              "minLength": 1,
              "type": "string"
            },
            "handle": {
              "minLength": 3,
              "type": "string"
            },
            "id": {
              "format": "uri",
              "minLength": 1,
              "pattern": "^https?://",
              "type": "string"
            },
            "key_id": {
              "type": "string"
            },
            "uri": {
              "format": "uri",
              "minLength": 1,
              "pattern": "^https?://",
              "type": "string"
            },
            "username": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "uri",
            "username",
            "domain",
            "handle"
          ],
          "type": "object"
        },
        "status": {
          "enum": [
            "online",
            "idle",
            "dnd",
            "offline",
            "invisible"
          ],
          "type": "string"
        },
        "ttl_ms": {
          "maximum": 86400000,
          "minimum": 100,
          "type": "integer"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "actor",
        "status",
        "updated_at"
      ],
      "type": "object"
    },
    "refs": {
      "properties": {
        "channel_id": {
          "minLength": 1,
          "type": "string"
        },
        "server_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "type": "object"
    },
    "server": {
      "type": "object"
    }
  },
  "required": [
    "presence"
  ],
  "title": "Arblarg presence.update payload",
  "type": "object"
}
