{
  "$id": "arblarg://schemas/1.0/thread.archive",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "actor": {
      "properties": {
        "avatar_url": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "domain": {
          "minLength": 1,
          "type": "string"
        },
        "handle": {
          "minLength": 3,
          "type": "string"
        },
        "id": {
          "format": "uri",
          "minLength": 1,
          "pattern": "^https?://",
          "type": "string"
        },
        "key_id": {
          "type": "string"
        },
        "uri": {
          "format": "uri",
          "minLength": 1,
          "pattern": "^https?://",
          "type": "string"
        },
        "username": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "uri",
        "username",
        "domain",
        "handle"
      ],
      "type": "object"
    },
    "archived_at": {
      "format": "date-time",
      "type": "string"
    },
    "channel": {
      "type": "object"
    },
    "reason": {
      "type": "string"
    },
    "server": {
      "type": "object"
    },
    "thread_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "server",
    "channel",
    "thread_id",
    "archived_at",
    "actor"
  ],
  "title": "Arblarg thread.archive payload",
  "type": "object"
}
