{
  "$id": "arblarg://schemas/1.0/thread.upsert",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "channel": {
      "type": "object"
    },
    "server": {
      "type": "object"
    },
    "thread": {
      "properties": {
        "channel_id": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "member_count": {
          "minimum": 0,
          "type": "integer"
        },
        "message_count": {
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "owner": {
          "properties": {
            "avatar_url": {
              "type": "string"
            },
            "display_name": {
              "type": "string"
            },
            "domain": {
              "minLength": 1,
              "type": "string"
            },
            "handle": {
              "minLength": 3,
              "type": "string"
            },
            "id": {
              "format": "uri",
              "minLength": 1,
              "pattern": "^https?://",
              "type": "string"
            },
            "key_id": {
              "type": "string"
            },
            "uri": {
              "format": "uri",
              "minLength": 1,
              "pattern": "^https?://",
              "type": "string"
            },
            "username": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "uri",
            "username",
            "domain",
            "handle"
          ],
          "type": "object"
        },
        "state": {
          "enum": [
            "active",
            "archived",
            "locked"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "channel_id",
        "name",
        "state",
        "owner"
      ],
      "type": "object"
    }
  },
  "required": [
    "server",
    "channel",
    "thread"
  ],
  "title": "Arblarg thread.upsert payload",
  "type": "object"
}
