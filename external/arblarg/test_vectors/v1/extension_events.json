{
  "name": "arbp-v1-extension-event-vectors",
  "cases": [
    {
      "id": "role_upsert",
      "event_type_alias": "role.upsert",
      "expected_event_type": "urn:arbp:ext:roles:1#role.upsert",
      "expected_schema": "role.upsert",
      "payload": {
        "server": {
          "id": "https://example.net/federation/messaging/servers/1"
        },
        "channel": {
          "id": "https://example.net/federation/messaging/channels/1"
        },
        "role": {
          "id": "role-admin",
          "name": "Admin",
          "permissions": [
            "manage_channels",
            "manage_messages"
          ],
          "position": 10
        }
      },
      "invalid_payload": {
        "server": {
          "id": "https://example.net/federation/messaging/servers/1"
        },
        "channel": {
          "id": "https://example.net/federation/messaging/channels/1"
        },
        "role": {
          "id": "role-admin",
          "permissions": [
            "manage_channels"
          ],
          "position": 10
        }
      },
      "expected_invalid_error": "invalid_event_payload"
    },
    {
