# Elektrine VPN fleet agent configuration.
# Copy to /etc/elektrine-vpn-agent.env and edit. Keep this file root-only (0600):
# it holds the fleet bootstrap key until the node is registered.

# --- Required ---

# Control-plane base URL (no trailing /api).
CONTROL_PLANE_URL=https://elektrine.example.com

# One-time bootstrap secret; must equal the control plane's
# VPN_FLEET_REGISTRATION_KEY. Only used until the node has registered; you may
# blank it afterwards (the node keeps its own api key in the state dir).
VPN_FLEET_REGISTRATION_KEY=change-me

# --- Node identity (recommended) ---

NODE_NAME=fra-edge-01
NODE_LOCATION=Frankfurt, Germany
NODE_COUNTRY_CODE=DE
NODE_CITY=Frankfurt
# PUBLIC_IP is autodetected from the default route if omitted.
# PUBLIC_IP=203.0.113.10
# ENDPOINT_HOST defaults to PUBLIC_IP. Set to a DNS name if you have one.
# ENDPOINT_HOST=fra-edge-01.vpn.example.com
ENDPOINT_PORT=51820

# --- Runtime (optional; defaults shown) ---

# WG_INTERFACE=wg0
# LISTEN_PORT=51820
# EGRESS_INTERFACE=          # autodetected from default route
# MANAGE_INTERFACE=1         # 0 to manage wg0 + NAT yourself
# POLL_INTERVAL=60
# ACTIVE_WINDOW=180
# STATE_DIR=/var/lib/elektrine-vpn
